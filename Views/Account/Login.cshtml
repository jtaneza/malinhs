@model MalikongkongNHS.Models.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Malikongkong NHS SErpS - Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

:root{
    --bg:#F8F9FA;
    --card:#FFFFFF;
    --sidebar:#2F3437;
    --sidebar-hover:#444B50;
    --sidebar-active:#1F2326;

    --text:#212529;
    --text-light:#6C757D;

    --border:#E9ECEF;

    --button:#2F3437;
    --button-hover:#1F2326;

    --accent:#495057;
}

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

body{
    min-height:100vh;
    background:#F8F9FA;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
}

.login-container{
    width:100%;
    max-width:1100px;
    min-height:650px;
    background:#FFFFFF;
    border-radius:24px;
    overflow:hidden;
    border:1px solid #E9ECEF;
    box-shadow:0 10px 30px rgba(0,0,0,.08);
    display:flex;
}

        /* LEFT SIDE */

.left-panel{
    width:50%;
    background:#FFFFFF;
    color:#212529;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    padding:50px;
    border-right:1px solid #E9ECEF;
}

        .logo{
            width:220px;
            margin-bottom:25px;
            transition:.3s;
        }

        .logo:hover{
            transform:scale(1.05);
        }

.school-title{
    font-size:2.4rem;
    font-weight:700;
    text-align:center;
    color:#C8102E;
}

.school-subtitle{
    margin-top:10px;
    font-size:1rem;
    color:#6C757D;
}

.divider{
    width:70px;
    height:4px;
    background:#C8102E;
    border-radius:20px;
    margin:25px 0;
}

.motto{
    color:#495057;
    font-weight:500;
    text-align:center;
}
        /* RIGHT SIDE */

.right-panel{
    width:50%;
    background:#FFFFFF;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:50px;
}
        .login-card{
            width:100%;
            max-width:450px;
        }

.login-title{
    font-size:3rem;
    font-weight:700;
    color:#C8102E;
    margin-bottom:35px;
}
        .form-label{
            font-weight:500;
            color:#333;
        }

.form-control{
    height:55px;
    border-radius:12px;
    border:1px solid #DEE2E6;
    background:#FFFFFF;
}

.form-control:focus{
    border-color:#C8102E;
    box-shadow:0 0 0 3px rgba(200,16,46,.15);
}

        .input-group .btn{
            border-radius:0 14px 14px 0;
            border:1px solid #dcdcdc;
        }

.btn-login{
    width:100%;
    height:55px;
    background:#C8102E;
    border:none;
    color:white;
    font-weight:600;
    border-radius:12px;
    transition:.3s;
}

.btn-login:hover{
    background:#A50D26;
    transform:translateY(-2px);
}

.forgot-link{
    text-decoration:none;
    color:#C8102E;
    font-weight:500;
}

.forgot-link:hover{
    color:#A50D26;
}

.copyright{
    text-align:center;
    margin-top:25px;
    color:#6C757D;
    font-size:.85rem;
}

        .validation-summary-errors{
            color:#dc3545;
            margin-bottom:15px;
        }

        .text-danger{
            font-size:.85rem;
        }

        @@media(max-width:992px){

            .login-container{
                flex-direction:column;
                min-height:auto;
            }

            .left-panel,
            .right-panel{
                width:100%;
            }

            .left-panel{
                padding:40px 20px;
            }

            .right-panel{
                padding:40px 25px;
            }

            .school-title{
                font-size:2rem;
            }

            .login-title{
                font-size:2.3rem;
                text-align:center;
            }

            .logo{
                width:170px;
            }
        }

        @@media(max-width:576px){

            .login-title{
                font-size:2rem;
            }

            .logo{
                width:140px;
            }

            .btn-login,
            .form-control{
                height:50px;
            }
        }

    </style>

</head>

<body>

<div class="login-container">

    <div class="left-panel">

        <img src="~/images/logo.png"
             class="logo"
             alt="School Logo">

        <h2 class="school-title">
            Malikongkong NHS
        </h2>

        <p class="school-subtitle">
            School ERP System
        </p>

        <div class="divider"></div>

        <p class="motto">
            Excellence • Integrity • Service
        </p>

    </div>

    <div class="right-panel">

        <div class="login-card">

            <h1 class="login-title">
                Welcome Back
            </h1>

            @if(ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">

                @Html.AntiForgeryToken()

                <div class="mb-3">

                    <label asp-for="Username" class="form-label"></label>

                    <input asp-for="Username"
                           class="form-control"
                           placeholder="Enter username" />

                    <span asp-validation-for="Username"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Password" class="form-label"></label>

                    <div class="input-group">

                        <input asp-for="Password"
                               id="password"
                               type="password"
                               class="form-control"
                               placeholder="Enter password" />

                        <button type="button"
                                class="btn btn-outline-secondary"
                                onclick="togglePassword()">

                            <i id="eyeIcon"
                               class="bi bi-eye"></i>

                        </button>

                    </div>

                    <span asp-validation-for="Password"
                          class="text-danger"></span>

                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <div class="form-check">

                        <input class="form-check-input"
                               type="checkbox"
                               id="rememberMe">

                        <label class="form-check-label"
                               for="rememberMe">

                            Remember Me

                        </label>

                    </div>

                    <a href="#"
                       class="forgot-link">

                        Forgot Password?

                    </a>

                </div>

                <button type="submit"
                        class="btn-login">

                    LOGIN

                </button>

            </form>

            <div class="copyright">
                © 2026 Malikongkong National High School
            </div>

        </div>

    </div>

</div>

<script>

    function togglePassword() {

        const password =
            document.getElementById("password");

        const eyeIcon =
            document.getElementById("eyeIcon");

        if (password.type === "password") {

            password.type = "text";

            eyeIcon.classList.remove("bi-eye");
            eyeIcon.classList.add("bi-eye-slash");

        }
        else {

            password.type = "password";

            eyeIcon.classList.remove("bi-eye-slash");
            eyeIcon.classList.add("bi-eye");
        }
    }

</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>