@model MalikongkongNHS.Models.ViewModels.AttendanceIndexVM

@{
    ViewData["Title"] = "Attendance";
}

<style>
    .page-title { font-size: 1.8rem; font-weight: 700; margin: 0; color: var(--primary); }

    /* STAT CARDS */
    .stat-card {
        background: #fff;
        border-radius: 16px;
        padding: 1.4rem 1.8rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        border-left: 4px solid transparent;
        transition: transform .2s ease, box-shadow .2s ease;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.12); }
    .stat-card-1 { border-left-color: #2E7D32; }
    .stat-card-2 { border-left-color: #C8102E; }
    .stat-card-3 { border-left-color: #D97706; }
    .stat-card-4 { border-left-color: #1565C0; }
    .stat-left { display: flex; flex-direction: column; align-items: flex-start; gap: .5rem; }
    .stat-icon {
        width: 48px; height: 48px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; flex-shrink: 0;
    }
    .icon-green  { background: rgba(46,125,50,.10);  color: #2E7D32; }
    .icon-red    { background: rgba(200,16,46,.10);   color: #C8102E; }
    .icon-yellow { background: rgba(217,119,6,.10);   color: #D97706; }
    .icon-blue   { background: rgba(21,101,192,.10);  color: #1565C0; }
    .stat-label  { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: #9CA3AF; white-space: nowrap; }
    .stat-number { font-size: 3rem; font-weight: 900; line-height: 1; color: #2C2C2C; letter-spacing: -2px; margin-left: auto; flex-shrink: 0; }

    .section-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.07);
        margin-bottom: 1.5rem;
    }

    .section-card h6 {
        font-weight: 700;
        color: var(--primary);
        border-bottom: 2px solid #f1f3f5;
        padding-bottom: .6rem;
        margin-bottom: 1rem;
    }

    .badge-present { background: #d1fae5; color: #065f46; }
    .badge-absent  { background: #fee2e2; color: #991b1b; }
    .badge-late    { background: #fef9c3; color: #854d0e; }
    .badge-excused { background: #e0e7ff; color: #3730a3; }

    .rate-bar  { height: 6px; border-radius: 4px; background: #e9ecef; overflow: hidden; }
    .rate-fill { height: 100%; border-radius: 4px; background: var(--secondary); }

    .btn-take {
        background: var(--secondary);
        color: #fff;
        border: none;
        padding: 10px 22px;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        transition: .3s;
    }

    .btn-take:hover { background: #a00d24; color: #fff; }
    .btn-take.disabled-btn { background: #adb5bd; pointer-events: none; }

    .btn-edit-status {
        background: #2c2c2c;
        color: #fff;
        border: none;
        padding: 4px 12px;
        border-radius: 7px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        transition: .2s;
    }

    .btn-edit-status:hover { background: #111; color: #fff; }
    .btn-edit-status:disabled { background: #adb5bd; cursor: not-allowed; }

    /* SEARCH + PAGINATION */
    .tbl-search-wrap { position:relative; max-width:260px; }
    .tbl-search-wrap i { position:absolute; left:10px; top:50%; transform:translateY(-50%); color:#9CA3AF; font-size:.82rem; pointer-events:none; }
    .tbl-search-wrap input { padding-left:32px; border-radius:10px; border:1.5px solid #dee2e6; font-size:.82rem; height:36px; width:100%; transition:border-color .2s; }
    .tbl-search-wrap input:focus { outline:none; border-color:#C8102E; box-shadow:0 0 0 3px rgba(200,16,46,.08); }
    .pager-wrap { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px; margin-top:10px; }
    .pager-info-txt { font-size:.76rem; color:#9CA3AF; }
    .pager-btns-wrap { display:flex; gap:4px; }
    .pg-btn { width:30px; height:30px; border-radius:8px; border:1.5px solid #dee2e6; background:#fff; display:flex; align-items:center; justify-content:center; font-size:.75rem; font-weight:700; cursor:pointer; color:#374151; transition:all .15s; }
    .pg-btn:hover:not(:disabled) { background:#C8102E; color:#fff; border-color:#C8102E; }
    .pg-btn.active { background:#C8102E; color:#fff; border-color:#C8102E; }
    .pg-btn:disabled { opacity:.4; cursor:not-allowed; }
</style>

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="page-title">Attendance</h1>
        <p class="text-muted mb-0">
            Section: <strong>@Model.SectionName</strong> &nbsp;|&nbsp;
            @(Model.IsAdviser ? "Advisory Class" : "Subject Teacher") &nbsp;|&nbsp;
            @DateTime.Today.ToString("MMMM dd, yyyy")
        </p>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
        @if (Model.AvailableSections.Count > 1)
        {
            <div style="position:relative;">
                <select id="sectionSwitcher" class="form-select form-select-sm"
                        style="min-width:190px;border-radius:10px;border:1.5px solid #dee2e6;font-size:.84rem;font-weight:600;"
                        onchange="switchSection(this.value)">
                    @foreach (var s in Model.AvailableSections)
                    {
                        if (s.SectionId == Model.SectionId)
                        {
                            <option value="@s.SectionId" selected="selected">
                                @s.SectionName — Grade @s.GradeLevel @(s.IsAdviser ? "(Adviser)" : "(Subject)")
                            </option>
                        }
                        else
                        {
                            <option value="@s.SectionId">
                                @s.SectionName — Grade @s.GradeLevel @(s.IsAdviser ? "(Adviser)" : "(Subject)")
                            </option>
                        }
                    }
                </select>
            </div>
        }
        @if (Model.AttendanceTakenToday)
        {
            <span class="btn-take disabled-btn">
                <i class="bi bi-check-circle me-1"></i> Attendance Taken
            </span>
        }
        else if (Model.SectionId > 0)
        {
            <a asp-action="Take" asp-route-sectionId="@Model.SectionId" class="btn-take">
                <i class="bi bi-clipboard-check me-1"></i> Take Attendance
            </a>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-1">
            <div class="stat-left">
                <div class="stat-icon icon-green"><i class="bi bi-person-check-fill"></i></div>
                <div class="stat-label">Present</div>
            </div>
            <div class="stat-number" style="color:#2E7D32">@Model.PresentToday</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-2">
            <div class="stat-left">
                <div class="stat-icon icon-red"><i class="bi bi-person-x-fill"></i></div>
                <div class="stat-label">Absent</div>
            </div>
            <div class="stat-number" style="color:#C8102E">@Model.AbsentToday</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-3">
            <div class="stat-left">
                <div class="stat-icon icon-yellow"><i class="bi bi-clock-fill"></i></div>
                <div class="stat-label">Late</div>
            </div>
            <div class="stat-number" style="color:#D97706">@Model.LateToday</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-4">
            <div class="stat-left">
                <div class="stat-icon icon-blue"><i class="bi bi-journal-check"></i></div>
                <div class="stat-label">Excused</div>
            </div>
            <div class="stat-number" style="color:#1565C0">@Model.ExcusedToday</div>
        </div>
    </div>
</div>

<!-- STUDENT SUMMARY -->
<div class="section-card mb-4">
    <h6><i class="bi bi-bar-chart-fill me-2 text-danger"></i>Student Attendance Summary</h6>

    @if (!Model.StudentSummaries.Any())
    {
        <p class="text-muted">No students enrolled in this section yet.</p>
    }
    else
    {
        <!-- Controls -->
        <div class="d-flex align-items-center gap-2 mb-3">
            <div class="tbl-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" id="summarySearch" placeholder="Search student…" oninput="summaryFilter()" />
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="summaryTable" style="table-layout:fixed; width:100%;">
                <colgroup>
                    <col style="width:14%" />
                    <col style="width:28%" />
                    <col style="width:12%"  />
                    <col style="width:12%"  />
                    <col style="width:12%"  />
                    <col style="width:12%"  />
                    <col style="width:10%" />
                </colgroup>
                <thead class="table-light">
                    <tr>
                        <th>LRN</th>
                        <th>Full Name</th>
                        <th class="text-center">Present</th>
                        <th class="text-center">Absent</th>
                        <th class="text-center">Late</th>
                        <th class="text-center">Excused</th>
                        <th class="text-center">Today</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.StudentSummaries)
                    {
                        <tr>
                            <td class="fw-semibold">@s.LRN</td>
                            <td>@s.FullName</td>
                            <td class="text-center"><span class="badge badge-present px-2">@s.Present</span></td>
                            <td class="text-center"><span class="badge badge-absent  px-2">@s.Absent</span></td>
                            <td class="text-center"><span class="badge badge-late    px-2">@s.Late</span></td>
                            <td class="text-center"><span class="badge badge-excused px-2">@s.Excused</span></td>
                            <td class="text-center">
                                @if (s.TodayAttendanceId.HasValue)
                                {
                                    <button type="button"
                                            class="btn-edit-status"
                                            onclick="openEditStatus(@s.TodayAttendanceId, '@s.FullName', '@s.TodayStatus')">
                                        <i class="bi bi-pencil-square me-1"></i>Edit
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size:.78rem;">No record</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="pager-wrap" id="summaryPager">
            <span class="pager-info-txt" id="summaryInfo"></span>
            <div class="pager-btns-wrap" id="summaryBtns"></div>
        </div>
    }
</div>

<!-- RECENT HISTORY -->
<div class="section-card">
    <h6><i class="bi bi-clock-history me-2 text-danger"></i>Recent Attendance History (Last 7 Days)</h6>

    @if (!Model.RecentHistory.Any())
    {
        <p class="text-muted mb-0">No attendance records yet.</p>
    }
    else
    {
        <!-- Search -->
        <div class="d-flex align-items-center gap-2 mb-3">
            <div class="tbl-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" id="historySearch" placeholder="Search name or date…" oninput="historyFilter()" />
            </div>
        </div>

        <div id="historyContainer">
            @foreach (var day in Model.RecentHistory)
            {
                <div class="history-day mb-3"
                     data-date="@day.Date.ToString("dddd mmmm dd yyyy").ToLower()"
                     data-names="@string.Join(" ", day.Records.Select(r => r.FullName + " " + r.Status)).ToLower()">
                    <p class="fw-semibold mb-1" style="font-size:.9rem;">
                        <i class="bi bi-calendar3 me-1 text-danger"></i>
                        @day.Date.ToString("dddd, MMMM dd yyyy")
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var r in day.Records)
                        {
                            <span class="badge @(r.Status == "Present" ? "badge-present" : r.Status == "Absent" ? "badge-absent" : r.Status == "Late" ? "badge-late" : "badge-excused") px-3 py-2">
                                @r.FullName — @r.Status
                            </span>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="pager-wrap" id="historyPager">
            <span class="pager-info-txt" id="historyInfo"></span>
            <div class="pager-btns-wrap" id="historyBtns"></div>
        </div>
    }
</div>

<!-- EDIT STATUS MODAL -->
<div class="modal fade" id="editStatusModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="border-radius:14px; overflow:hidden; border:none;">

            <div class="modal-header" style="background:linear-gradient(135deg,#2c2c2c,#444); color:#fff; border:none;">
                <h6 class="modal-title mb-0">
                    <i class="bi bi-pencil-square me-2"></i>Edit Attendance
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form asp-action="EditStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="attendanceId" id="editAttendanceId" />
                <input type="hidden" name="returnSectionId" value="@Model.SectionId" />

                <div class="modal-body p-4">
                    <p class="mb-3">
                        Changing attendance for:<br/>
                        <strong id="editStudentName"></strong>
                    </p>

                    <label class="form-label fw-semibold">Status</label>
                    <select name="status" id="editStatusSelect" class="form-select">
                        <option value="Present">Present</option>
                        <option value="Absent">Absent</option>
                        <option value="Late">Late</option>
                        <option value="Excused">Excused</option>
                    </select>
                </div>

                <div class="modal-footer" style="border-top:1px solid #f0f0f0; background:#fafafa;">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm"
                            style="background:var(--secondary);color:#fff;border:none;border-radius:8px;padding:6px 18px;font-weight:600;">
                        <i class="bi bi-save me-1"></i>Save
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

<script>
    // ── Edit Status Modal ──────────────────────────────────────
    function openEditStatus(attendanceId, fullName, currentStatus) {
        document.getElementById('editAttendanceId').value  = attendanceId;
        document.getElementById('editStudentName').textContent = fullName;
        document.getElementById('editStatusSelect').value  = currentStatus;
        new bootstrap.Modal(document.getElementById('editStatusModal')).show();
    }

    // ── STUDENT SUMMARY: search + pagination ──────────────────
    const SUMMARY_PER_PAGE = 5;
    let summaryPage = 1;
    let summaryFiltered = [];

    function summaryAllRows() {
        return Array.from(document.querySelectorAll('#summaryTable tbody tr'));
    }

    function summaryFilter() {
        const q = (document.getElementById('summarySearch')?.value || '').toLowerCase();
        summaryFiltered = summaryAllRows().filter(r => r.innerText.toLowerCase().includes(q));
        summaryPage = 1;
        summaryRender();
    }

    function summaryRender() {
        const total = summaryFiltered.length;
        const pages = Math.max(1, Math.ceil(total / SUMMARY_PER_PAGE));
        if (summaryPage > pages) summaryPage = pages;

        summaryAllRows().forEach(r => r.style.display = 'none');
        const start = (summaryPage - 1) * SUMMARY_PER_PAGE;
        summaryFiltered.slice(start, start + SUMMARY_PER_PAGE).forEach(r => r.style.display = '');

        const infoEl = document.getElementById('summaryInfo');
        if (infoEl) {
            const from = total === 0 ? 0 : start + 1;
            const to   = Math.min(start + SUMMARY_PER_PAGE, total);
            infoEl.textContent = `Showing ${from}–${to} of ${total} student${total !== 1 ? 's' : ''}`;
        }

        const btnsEl = document.getElementById('summaryBtns');
        if (!btnsEl) return;
        btnsEl.innerHTML = '';

        const prev = document.createElement('button');
        prev.className = 'pg-btn';
        prev.innerHTML = '<i class="bi bi-chevron-left"></i>';
        prev.disabled  = summaryPage === 1;
        prev.onclick   = () => { summaryPage--; summaryRender(); };
        btnsEl.appendChild(prev);

        for (let i = 1; i <= pages; i++) {
            const btn = document.createElement('button');
            btn.className = 'pg-btn' + (i === summaryPage ? ' active' : '');
            btn.textContent = i;
            btn.onclick = () => { summaryPage = i; summaryRender(); };
            btnsEl.appendChild(btn);
        }

        const next = document.createElement('button');
        next.className = 'pg-btn';
        next.innerHTML = '<i class="bi bi-chevron-right"></i>';
        next.disabled  = summaryPage === pages;
        next.onclick   = () => { summaryPage++; summaryRender(); };
        btnsEl.appendChild(next);
    }

    // ── RECENT HISTORY: search + pagination ───────────────────
    const HISTORY_PER_PAGE = 5;
    let historyPage = 1;
    let historyFiltered = [];

    function historyAllDays() {
        return Array.from(document.querySelectorAll('#historyContainer .history-day'));
    }

    function historyFilter() {
        const q = (document.getElementById('historySearch')?.value || '').toLowerCase();
        historyFiltered = historyAllDays().filter(d =>
            d.dataset.date.includes(q) || d.dataset.names.includes(q)
        );
        historyPage = 1;
        historyRender();
    }

    function historyRender() {
        const total = historyFiltered.length;
        const pages = Math.max(1, Math.ceil(total / HISTORY_PER_PAGE));
        if (historyPage > pages) historyPage = pages;

        historyAllDays().forEach(d => d.style.display = 'none');
        const start = (historyPage - 1) * HISTORY_PER_PAGE;
        historyFiltered.slice(start, start + HISTORY_PER_PAGE).forEach(d => d.style.display = '');

        const infoEl = document.getElementById('historyInfo');
        if (infoEl) {
            const from = total === 0 ? 0 : start + 1;
            const to   = Math.min(start + HISTORY_PER_PAGE, total);
            infoEl.textContent = `Showing ${from}–${to} of ${total} day${total !== 1 ? 's' : ''}`;
        }

        const btnsEl = document.getElementById('historyBtns');
        if (!btnsEl) return;
        btnsEl.innerHTML = '';

        const prev = document.createElement('button');
        prev.className = 'pg-btn';
        prev.innerHTML = '<i class="bi bi-chevron-left"></i>';
        prev.disabled  = historyPage === 1;
        prev.onclick   = () => { historyPage--; historyRender(); };
        btnsEl.appendChild(prev);

        for (let i = 1; i <= pages; i++) {
            const btn = document.createElement('button');
            btn.className = 'pg-btn' + (i === historyPage ? ' active' : '');
            btn.textContent = i;
            btn.onclick = () => { historyPage = i; historyRender(); };
            btnsEl.appendChild(btn);
        }

        const next = document.createElement('button');
        next.className = 'pg-btn';
        next.innerHTML = '<i class="bi bi-chevron-right"></i>';
        next.disabled  = historyPage === pages;
        next.onclick   = () => { historyPage++; historyRender(); };
        btnsEl.appendChild(next);
    }

    // ── Init on DOM ready ──────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        summaryFilter();
        historyFilter();
    });

    // ── Section switcher ───────────────────────────────────────
    function switchSection(sectionId) {
        window.location.href = '/Attendance/Index?sectionId=' + sectionId;
    }
</script>