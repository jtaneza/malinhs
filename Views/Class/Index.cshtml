@model List<MalikongkongNHS.Models.ViewModels.TeacherClassVM>

@{
    ViewData["Title"] = "My Classes";
    int totalStudents    = Model.Sum(s => s.Students.Count);
    int advisoryCount    = Model.Count(s => s.IsAdviser);
    int subjectOnlyCount = Model.Count(s => !s.IsAdviser);
}

<style>
/* ── HEADER ── */
.page-title  { font-size:2rem; font-weight:700; color:#2C2C2C; margin:0; }
.date-badge  {
    background:#fff; color:#C8102E; padding:6px 16px; border-radius:20px;
    font-size:.875rem; font-weight:600; border:1.5px solid rgba(200,16,46,.2);
    box-shadow:0 2px 6px rgba(200,16,46,.08);
}

/* ── SECTION SWITCHER ── */
.switcher-bar {
    display:flex; align-items:center; gap:10px; flex-wrap:wrap;
    background:#fff; border-radius:14px; padding:.8rem 1.2rem;
    box-shadow:0 2px 10px rgba(0,0,0,.07); margin-bottom:1.5rem;
    border-left:4px solid #C8102E;
}
.switcher-label { font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.5px; color:#9CA3AF; white-space:nowrap; }
.section-pill {
    display:inline-flex; align-items:center; gap:6px;
    padding:6px 16px; border-radius:20px; font-size:.82rem; font-weight:600;
    border:1.5px solid #dee2e6; background:#F9FAFB; color:#374151;
    cursor:pointer; transition:all .2s; text-decoration:none;
}
.section-pill:hover { border-color:#C8102E; color:#C8102E; background:#fff5f5; }
.section-pill.active { background:#C8102E; color:#fff; border-color:#C8102E; }
.section-pill .pill-badge {
    font-size:.6rem; padding:1px 6px; border-radius:10px;
    font-weight:700; letter-spacing:.3px;
}
.pill-badge-adviser { background:rgba(255,255,255,.25); color:#fff; }
.pill-badge-subject { background:rgba(200,16,46,.12); color:#C8102E; }
.section-pill.active .pill-badge-subject { background:rgba(255,255,255,.25); color:#fff; }

/* ── STAT CARDS ── */
.stat-card{
    background:#fff; border-radius:16px; padding:1.4rem 1.8rem;
    display:flex; align-items:center; justify-content:space-between; gap:1rem;
    box-shadow:0 2px 12px rgba(0,0,0,.07);
    transition:transform .2s ease,box-shadow .2s ease;
    border-left:4px solid transparent;
}
.stat-card:hover{ transform:translateY(-3px); box-shadow:0 6px 20px rgba(0,0,0,.12); }
.stat-card-1{ border-left-color:#C8102E; }
.stat-card-2{ border-left-color:#2E7D32; }
.stat-card-3{ border-left-color:#1565C0; }

.stat-left{ display:flex; flex-direction:column; align-items:flex-start; gap:.5rem; }
.stat-icon{
    width:48px; height:48px; border-radius:12px;
    display:flex; align-items:center; justify-content:center;
    font-size:1.4rem; flex-shrink:0;
}
.icon-red    { background:rgba(200,16,46,.10); color:#C8102E; }
.icon-green  { background:rgba(46,125,50,.10);  color:#2E7D32; }
.icon-blue   { background:rgba(21,101,192,.10); color:#1565C0; }
.stat-label  {
    font-size:.72rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.6px; color:#9CA3AF; white-space:nowrap;
}
.stat-number {
    font-size:3rem; font-weight:900; line-height:1; color:#2C2C2C;
    letter-spacing:-2px; margin-left:auto; flex-shrink:0;
}

/* ── SECTION BLOCK ── */
.section-block{
    background:#fff; border-radius:16px;
    padding:1.4rem 1.6rem; margin-bottom:1.5rem;
    box-shadow:0 2px 12px rgba(0,0,0,.07);
    border-left:4px solid #C8102E;
    display:none; /* hidden by default; JS shows the selected one */
}
.section-block.active-section { display:block; }
.section-block.subject-only   { border-left-color:#1565C0; }
.section-title{ font-size:1.15rem; font-weight:700; color:#2C2C2C; margin:0; }
.meta-badge{
    display:inline-block; padding:3px 10px; border-radius:20px;
    font-size:.72rem; font-weight:700;
}
.meta-blue   { background:rgba(21,101,192,.1); color:#1565C0; }
.meta-red    { background:rgba(200,16,46,.1);  color:#C8102E; }
.meta-dark   { background:rgba(44,44,44,.08);  color:#2C2C2C; }
.meta-adviser{ background:rgba(200,16,46,.12); color:#C8102E; }
.meta-subject{ background:rgba(21,101,192,.12);color:#1565C0; }
.student-count-badge{
    background:#C8102E; color:#fff; padding:4px 14px; border-radius:20px;
    font-size:.82rem; font-weight:700; display:inline-flex; align-items:center; gap:4px;
}
.subject-count-badge{
    background:#1565C0; color:#fff; padding:4px 14px; border-radius:20px;
    font-size:.82rem; font-weight:700; display:inline-flex; align-items:center; gap:4px;
}

/* ── CONTROLS (search + show) ── */
.table-controls{
    display:flex; align-items:center; justify-content:space-between;
    gap:12px; flex-wrap:wrap; margin-bottom:14px; margin-top:14px;
}
.search-wrap{ position:relative; flex:1; min-width:180px; max-width:300px; }
.search-wrap i{
    position:absolute; left:11px; top:50%; transform:translateY(-50%);
    color:#9CA3AF; font-size:.9rem; pointer-events:none;
}
.search-wrap input{
    padding-left:34px; border-radius:10px; border:1.5px solid #dee2e6;
    font-size:.82rem; height:36px; width:100%;
    transition:border-color .2s;
}
.search-wrap input:focus{ outline:none; border-color:#C8102E; box-shadow:0 0 0 3px rgba(200,16,46,.08); }
.show-select{ font-size:.82rem; border-radius:10px; border:1.5px solid #dee2e6; padding:4px 10px; }

/* ── TABLE ── */
.class-table th{
    font-size:.72rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.5px; color:#9CA3AF; border-bottom:1.5px solid #F0F0F0;
    padding:10px 12px; background:transparent;
}
.class-table td{
    font-size:.84rem; padding:10px 12px; vertical-align:middle;
    border-bottom:1px solid #F8F9FA; color:#374151;
}
.class-table tbody tr:last-child td{ border-bottom:none; }
.class-table tbody tr:hover td{ background:#FAFAFA; }

/* ── PAGINATION ── */
.pager{ display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px; margin-top:12px; }
.pager-info{ font-size:.78rem; color:#9CA3AF; }
.pager-btns{ display:flex; gap:4px; }
.pager-btn{
    width:32px; height:32px; border-radius:8px; border:1.5px solid #dee2e6;
    background:#fff; display:flex; align-items:center; justify-content:center;
    font-size:.78rem; font-weight:700; cursor:pointer; color:#374151;
    transition:all .15s;
}
.pager-btn:hover:not(:disabled){ background:#C8102E; color:#fff; border-color:#C8102E; }
.pager-btn.active{ background:#C8102E; color:#fff; border-color:#C8102E; }
.pager-btn:disabled{ opacity:.4; cursor:not-allowed; }
</style>

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">My Classes</h1>
        <p class="text-muted mb-0">View your assigned sections and student lists.</p>
    </div>
    <span class="date-badge">
        <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("MMMM dd, yyyy")
    </span>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-easel2" style="font-size:3rem;opacity:.3"></i>
        <h5 class="mt-3">No Classes Assigned Yet</h5>
        <p>You have no sections assigned. Please contact the admin.</p>
    </div>
}
else
{
    <!-- STAT CARDS -->
    <div class="row g-3 mb-4">
        <div class="col-md-4 col-xl-3">
            <div class="stat-card stat-card-1">
                <div class="stat-left">
                    <div class="stat-icon icon-red"><i class="bi bi-easel2-fill"></i></div>
                    <div class="stat-label">Total Sections</div>
                </div>
                <div class="stat-number" style="color:#C8102E">@Model.Count</div>
            </div>
        </div>
        <div class="col-md-4 col-xl-3">
            <div class="stat-card stat-card-2">
                <div class="stat-left">
                    <div class="stat-icon icon-green"><i class="bi bi-mortarboard-fill"></i></div>
                    <div class="stat-label">Total Students</div>
                </div>
                <div class="stat-number" style="color:#2E7D32">@totalStudents</div>
            </div>
        </div>
        @if (advisoryCount > 0)
        {
            <div class="col-md-4 col-xl-3">
                <div class="stat-card stat-card-3">
                    <div class="stat-left">
                        <div class="stat-icon icon-blue"><i class="bi bi-person-workspace"></i></div>
                        <div class="stat-label">Advisory Classes</div>
                    </div>
                    <div class="stat-number" style="color:#1565C0">@advisoryCount</div>
                </div>
            </div>
        }
    </div>

    <!-- SECTION SWITCHER (only if more than 1 section) -->
    @if (Model.Count > 1)
    {
        <div class="switcher-bar mb-3">
            <span class="switcher-label"><i class="bi bi-grid-3x3-gap me-1"></i>Switch Section:</span>
            @foreach (var cls in Model)
            {
                <a href="javascript:void(0)"
                   class="section-pill @(Model.IndexOf(cls) == 0 ? "active" : "")"
                   data-section-index="@Model.IndexOf(cls)"
                   onclick="showSection(@Model.IndexOf(cls), this)">
                    <i class="bi @(cls.IsAdviser ? "bi-person-heart" : "bi-book-fill")"></i>
                    @cls.SectionName
                    <span class="pill-badge @(cls.IsAdviser ? "pill-badge-adviser" : "pill-badge-subject")">
                        @(cls.IsAdviser ? "Adviser" : "Subject")
                    </span>
                </a>
            }
        </div>
    }

    <!-- SECTION BLOCKS -->
    @foreach (var cls in Model)
    {
        var sectionIdx = Model.IndexOf(cls);
        var tableId   = $"tbl_{sectionIdx}";
        var searchId  = $"srch_{sectionIdx}";
        var showId    = $"show_{sectionIdx}";
        var pagerId   = $"pgr_{sectionIdx}";
        var infoId    = $"info_{sectionIdx}";
        var isFirst   = sectionIdx == 0;

        <div class="section-block @(isFirst ? "active-section" : "") @(!cls.IsAdviser ? "subject-only" : "")"
             id="section_@sectionIdx">

            <!-- Section header -->
            <div class="d-flex align-items-start justify-content-between flex-wrap gap-2">
                <div>
                    <h5 class="section-title">
                        <i class="bi @(cls.IsAdviser ? "bi-person-heart text-danger" : "bi-book-fill text-primary") me-2"></i>@cls.SectionName
                    </h5>
                    <div class="d-flex gap-2 mt-1 flex-wrap align-items-center">
                        <span class="meta-badge meta-blue">Grade @cls.GradeLevel</span>
                        <span class="meta-badge meta-red">Capacity: @cls.Capacity</span>
                        @if (cls.IsAdviser)
                        {
                            <span class="meta-badge meta-adviser"><i class="bi bi-person-heart me-1"></i>Advisory Class</span>
                        }
                        else
                        {
                            <span class="meta-badge meta-subject"><i class="bi bi-book me-1"></i>Subject Teacher</span>
                            <span class="meta-badge meta-dark" style="font-size:.68rem;"><i class="bi bi-person-lines-fill me-1"></i>Adviser: @cls.Adviser</span>
                        }
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    @if (cls.IsAdviser)
                    {
                        <span class="student-count-badge">
                            <i class="bi bi-people-fill"></i>@cls.Students.Count Students
                        </span>
                    }
                    else
                    {
                        <span class="subject-count-badge">
                            <i class="bi bi-people-fill"></i>@cls.Students.Count Students
                        </span>
                    }
                    <a asp-controller="Class" asp-action="Students"
                       asp-route-sectionId="@cls.SectionId"
                       class="btn btn-sm"
                       style="background:@(cls.IsAdviser ? "#C8102E" : "#1565C0");color:#fff;border-radius:10px;font-weight:600;font-size:.8rem;padding:5px 14px">
                        <i class="bi bi-eye me-1"></i>View All
                    </a>
                </div>
            </div>

            @if (cls.Students.Any())
            {
                <!-- Controls -->
                <div class="table-controls">
                    <div class="search-wrap">
                        <i class="bi bi-search"></i>
                        <input type="text" id="@searchId" placeholder="Search students…"
                               oninput="filterTable('@tableId','@searchId','@pagerId','@infoId',parseInt(document.getElementById('@showId').value))" />
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label style="font-size:.78rem;color:#9CA3AF;white-space:nowrap">Show</label>
                        <select id="@showId" class="show-select"
                                onchange="filterTable('@tableId','@searchId','@pagerId','@infoId',parseInt(this.value))">
                            <option value="5">5</option>
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <span style="font-size:.78rem;color:#9CA3AF">entries</span>
                    </div>
                </div>

                <!-- Table -->
                <div class="table-responsive">
                    <table class="table class-table mb-0" id="@tableId">
                        <thead>
                            <tr>
                                <th style="width:14%">Student No.</th>
                                <th style="width:28%">Full Name</th>
                                <th style="width:12%">Gender</th>
                                <th style="width:26%">Guardian</th>
                                <th style="width:20%">Contact</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in cls.Students)
                            {
                                <tr>
                                    <td><strong>@student.StudentNo</strong></td>
                                    <td>@student.FullName</td>
                                    <td>@student.Gender</td>
                                    <td>@student.GuardianName</td>
                                    <td>@student.ContactNumber</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="pager" id="@pagerId">
                    <span class="pager-info" id="@infoId"></span>
                    <div class="pager-btns" id="@(pagerId)_btns"></div>
                </div>
            }
            else
            {
                <p class="text-muted mb-0 mt-3" style="font-size:.9rem;">
                    <i class="bi bi-info-circle me-1"></i>No students enrolled yet.
                </p>
            }
        </div>
    }
}

<script>
// ── Section switcher ──────────────────────────────────────────
function showSection(index, pill) {
    // hide all blocks
    document.querySelectorAll('.section-block').forEach(b => b.classList.remove('active-section'));
    // deactivate all pills
    document.querySelectorAll('.section-pill').forEach(p => p.classList.remove('active'));
    // show the selected block
    const block = document.getElementById('section_' + index);
    if (block) block.classList.add('active-section');
    // activate the pill
    if (pill) pill.classList.add('active');
    // reinit table for the newly shown section
    const tblId   = 'tbl_'  + index;
    const pgrId   = 'pgr_'  + index;
    const infoId  = 'info_' + index;
    const showId  = 'show_' + index;
    const srchId  = 'srch_' + index;
    const perPage = parseInt(document.getElementById(showId)?.value || '5');
    filterTable(tblId, srchId, pgrId, infoId, perPage);
}

// ── state per table ──────────────────────────────────────────
const _state = {};

// ── filter + paginate ────────────────────────────────────────
function filterTable(tableId, searchId, pagerId, infoId, perPage) {
    const tbl    = document.getElementById(tableId);
    if (!tbl) return;
    const search = (document.getElementById(searchId)?.value || '').toLowerCase();
    const rows   = Array.from(tbl.querySelectorAll('tbody tr'));

    const visible = rows.filter(row => {
        const match = row.textContent.toLowerCase().includes(search);
        row.style.display = 'none';
        return match;
    });

    if (!_state[tableId]) _state[tableId] = { page: 1 };
    if (search !== (_state[tableId].lastSearch || '')) {
        _state[tableId].page = 1;
        _state[tableId].lastSearch = search;
    }

    const totalFiltered = visible.length;
    const totalPages    = Math.max(1, Math.ceil(totalFiltered / perPage));
    let   currentPage   = Math.min(_state[tableId].page, totalPages);
    _state[tableId].page = currentPage;

    const start = (currentPage - 1) * perPage;
    const end   = start + perPage;
    visible.forEach((row, i) => {
        row.style.display = (i >= start && i < end) ? '' : 'none';
    });

    const infoEl = document.getElementById(infoId);
    if (infoEl) {
        const from = totalFiltered === 0 ? 0 : start + 1;
        const to   = Math.min(end, totalFiltered);
        infoEl.textContent = `Showing ${from}–${to} of ${totalFiltered} student${totalFiltered !== 1 ? 's' : ''}`;
    }

    const btnsEl = document.getElementById(pagerId + '_btns');
    if (!btnsEl) return;
    btnsEl.innerHTML = '';

    const prev = document.createElement('button');
    prev.className = 'pager-btn';
    prev.innerHTML = '<i class="bi bi-chevron-left"></i>';
    prev.disabled  = currentPage === 1;
    prev.onclick   = () => { _state[tableId].page = currentPage - 1; filterTable(tableId, searchId, pagerId, infoId, perPage); };
    btnsEl.appendChild(prev);

    getPageRange(currentPage, totalPages).forEach(p => {
        const btn = document.createElement('button');
        btn.className = 'pager-btn' + (p === currentPage ? ' active' : '');
        btn.textContent = p;
        btn.disabled = p === '…';
        btn.onclick = p === '…' ? null : () => { _state[tableId].page = p; filterTable(tableId, searchId, pagerId, infoId, perPage); };
        btnsEl.appendChild(btn);
    });

    const next = document.createElement('button');
    next.className = 'pager-btn';
    next.innerHTML = '<i class="bi bi-chevron-right"></i>';
    next.disabled  = currentPage === totalPages;
    next.onclick   = () => { _state[tableId].page = currentPage + 1; filterTable(tableId, searchId, pagerId, infoId, perPage); };
    btnsEl.appendChild(next);
}

function getPageRange(current, total) {
    if (total <= 7) return Array.from({length: total}, (_, i) => i + 1);
    if (current <= 4) return [1,2,3,4,5,'…',total];
    if (current >= total - 3) return [1,'…',total-4,total-3,total-2,total-1,total];
    return [1,'…',current-1,current,current+1,'…',total];
}

// ── Init AFTER DOM is ready ──────────────────────────────────
document.addEventListener('DOMContentLoaded', function () {
    // Only init the first (active) section's table
    filterTable('tbl_0', 'srch_0', 'pgr_0', 'info_0', 5);
});
</script>
