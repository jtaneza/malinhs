@model MalikongkongNHS.Models.ViewModels.DashboardVM

@{
    ViewData["Title"] = "Dashboard";
}

<style>
.dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 15px;
}

.page-title {
    color: #2C2C2C;
    font-size: 3rem;
    font-weight: 700;
    margin: 0;
}

.date-badge {
    background: #2C2C2C;
    color: white;
    padding: 10px 16px;
    border-radius: 8px;
    font-weight: 600;
}

/* ── STAT CARDS (same as Attendance) ─────────────────── */
.stat-card {
    background: #fff;
    border-radius: 16px;
    padding: 1.4rem 1.8rem;
    box-shadow: 0 2px 12px rgba(0,0,0,.07);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-left: 4px solid transparent;
    transition: transform .2s ease, box-shadow .2s ease;
}
.stat-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.12); }
.stat-card-students { border-left-color: #C8102E; }
.stat-card-teachers { border-left-color: #2E7D32; }
.stat-card-sections { border-left-color: #D97706; }
.stat-card-users    { border-left-color: #1565C0; }

.stat-left  { display: flex; flex-direction: column; align-items: flex-start; gap: .5rem; }
.stat-icon  {
    width: 48px; height: 48px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; flex-shrink: 0;
}
.icon-red    { background: rgba(200,16,46,.10);   color: #C8102E; }
.icon-green  { background: rgba(46,125,50,.10);   color: #2E7D32; }
.icon-yellow { background: rgba(217,119,6,.10);   color: #D97706; }
.icon-blue   { background: rgba(21,101,192,.10);  color: #1565C0; }

.stat-label  {
    font-size: .72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .6px; color: #9CA3AF; white-space: nowrap;
}
.stat-number {
    font-size: 3rem; font-weight: 900; line-height: 1;
    color: #2C2C2C; letter-spacing: -2px; margin-left: auto; flex-shrink: 0;
}

/* ── SECTION CARDS ─────────────────────────────────── */
.section-card {
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
}
.section-card .card-header-custom {
    font-weight: 700;
    color: var(--primary, #2C2C2C);
    border-bottom: 2px solid #f1f3f5;
    padding-bottom: .6rem;
    margin-bottom: 1rem;
    font-size: .95rem;
}

/* ── ACTIVITY LIST ─────────────────────────────────── */
.activity-item {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
    padding: .65rem 0;
    border-bottom: 1px solid #f1f3f5;
}
.activity-item:last-child { border-bottom: none; }
.activity-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: #C8102E; margin-top: 6px; flex-shrink: 0;
}
.activity-msg  { font-size: .86rem; color: #374151; line-height: 1.4; }
.activity-time { font-size: .73rem; color: #9CA3AF; margin-top: 2px; }
.no-activity   { font-size: .85rem; color: #9CA3AF; }
</style>

<!-- HEADER -->
<div class="dashboard-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="text-muted mb-0">Welcome back, Admin. Here's what's happening today.</p>
    </div>
    <div>
        <span class="date-badge">@DateTime.Now.ToString("MMMM dd, yyyy")</span>
    </div>
</div>

<!-- STAT CARDS -->
<div class="row g-3 mt-3">

    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-students">
            <div class="stat-left">
                <div class="stat-icon icon-red"><i class="bi bi-mortarboard-fill"></i></div>
                <div class="stat-label">Total Students</div>
            </div>
            <div class="stat-number" style="color:#C8102E">@Model.TotalStudents</div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-teachers">
            <div class="stat-left">
                <div class="stat-icon icon-green"><i class="bi bi-person-workspace"></i></div>
                <div class="stat-label">Total Teachers</div>
            </div>
            <div class="stat-number" style="color:#2E7D32">@Model.TotalTeachers</div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-sections">
            <div class="stat-left">
                <div class="stat-icon icon-yellow"><i class="bi bi-diagram-3-fill"></i></div>
                <div class="stat-label">Total Sections</div>
            </div>
            <div class="stat-number" style="color:#D97706">@Model.TotalSections</div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="stat-card stat-card-users">
            <div class="stat-left">
                <div class="stat-icon icon-blue"><i class="bi bi-people-fill"></i></div>
                <div class="stat-label">Total Users</div>
            </div>
            <div class="stat-number" style="color:#1565C0">@Model.TotalUsers</div>
        </div>
    </div>

</div>

<!-- CHART + RECENT ACTIVITIES -->
<div class="row mt-4">

    <!-- ── ENROLLMENT TREND CHART ──────────────────────── -->
    <div class="col-lg-8 mb-4">
        <div class="section-card h-100">
            <div class="card-header-custom d-flex align-items-center justify-content-between">
                <span><i class="bi bi-bar-chart-line-fill me-2 text-danger"></i>Student Enrollment Trend</span>
                <small class="text-muted" style="font-size:.72rem;font-weight:600;">Total enrolled students per month (last 8 months)</small>
            </div>

            <div style="position:relative; height:220px;">
                <canvas id="enrollmentChart"></canvas>
            </div>

            @{
                var firstMonth = Model.MonthlyEnrollment.FirstOrDefault();
                var lastMonth  = Model.MonthlyEnrollment.LastOrDefault();
                var growth     = lastMonth - firstMonth;
            }
            <div class="row g-2 mt-3">
                <div class="col-4 text-center" style="border-right:1px solid #f1f3f5;">
                    <div style="font-size:1.5rem;font-weight:900;color:#C8102E;">@lastMonth</div>
                    <div style="font-size:.68rem;font-weight:700;text-transform:uppercase;color:#9CA3AF;">Current Total</div>
                </div>
                <div class="col-4 text-center" style="border-right:1px solid #f1f3f5;">
                    <div style="font-size:1.5rem;font-weight:900;color:#2E7D32;">@firstMonth</div>
                    <div style="font-size:.68rem;font-weight:700;text-transform:uppercase;color:#9CA3AF;">8 Months Ago</div>
                </div>
                <div class="col-4 text-center">
                    <div style="font-size:1.5rem;font-weight:900;color:@(growth >= 0 ? "#1565C0" : "#C8102E");">@(growth >= 0 ? "+" : "")@growth</div>
                    <div style="font-size:.68rem;font-weight:700;text-transform:uppercase;color:#9CA3AF;">Growth</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── RECENT ACTIVITIES ───────────────────────────── -->
    <div class="col-lg-4 mb-4">
        <div class="section-card h-100 d-flex flex-column">
            <div class="card-header-custom d-flex align-items-center justify-content-between">
                <span><i class="bi bi-clock-history me-2 text-danger"></i>Recent Activities</span>
                <a href="/AuditLog/Index" style="font-size:.72rem;color:#C8102E;font-weight:700;text-decoration:none;">
                    View All <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div style="flex:1; overflow-y:auto; max-height:340px;">
                @if (!Model.RecentActivities.Any())
                {
                    <div style="text-align:center;padding:2.5rem 1rem;">
                        <i class="bi bi-inbox" style="font-size:2.5rem;color:#dee2e6;"></i>
                        <p class="no-activity mt-2">No recent activities recorded yet.</p>
                    </div>
                }
                else
                {
                    foreach (var act in Model.RecentActivities)
                    {
                        var roleStr = act.Message.Contains('[') && act.Message.Contains(']')
                                      ? act.Message.Substring(act.Message.IndexOf('[')+1, act.Message.IndexOf(']')-act.Message.IndexOf('[')-1)
                                      : "System";

                        var dotColor = roleStr == "Admin" ? "#C8102E" :
                                       roleStr == "Cashier" ? "#1565C0" :
                                       roleStr == "Teacher" ? "#2E7D32" :
                                       roleStr == "Student" ? "#D97706" : "#9CA3AF";

                        var diff = DateTime.Now - act.CreatedAt;
                        var timeAgo = diff.TotalMinutes < 1 ? "just now"
                                    : diff.TotalHours < 1 ? $"{(int)diff.TotalMinutes}m ago"
                                    : diff.TotalDays < 1 ? $"{(int)diff.TotalHours}h ago"
                                    : diff.TotalDays < 7 ? $"{(int)diff.TotalDays}d ago"
                                    : act.CreatedAt.ToString("MMM dd");

                        var shortMsg = act.Message.Length > 72 ? act.Message[..72] + "…" : act.Message;

                        <div class="activity-item" style="padding:.65rem 0;border-bottom:1px solid #f1f3f5;gap:.6rem;">
                            <div style="width:8px;height:8px;border-radius:50%;background:@dotColor;margin-top:6px;flex-shrink:0;"></div>
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:.80rem;line-height:1.4;color:#374151;" title="@act.Message">@shortMsg</div>
                                <div class="d-flex align-items-center gap-2 mt-1">
                                    <span style="font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:4px;background:rgba(200,16,46,.08);color:@dotColor;">@roleStr</span>
                                    <span style="font-size:.68rem;color:#9CA3AF;">@timeAgo</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById("enrollmentChart");

    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthLabels));
    const data   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyEnrollment));

    new Chart(ctx, {
        type: "line",
        data: {
            labels: labels,
            datasets: [{
                label: "Students Enrolled",
                data: data,
                borderColor: "#C8102E",
                backgroundColor: function(ctx) {
                    const chart = ctx.chart;
                    const { ctx: c, chartArea } = chart;
                    if (!chartArea) return "rgba(200,16,46,0.08)";
                    const grad = c.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
                    grad.addColorStop(0, "rgba(200,16,46,0.18)");
                    grad.addColorStop(1, "rgba(200,16,46,0.01)");
                    return grad;
                },
                fill: true,
                tension: 0.4,
                borderWidth: 2.5,
                pointBackgroundColor: "#fff",
                pointBorderColor: "#C8102E",
                pointBorderWidth: 2,
                pointRadius: 5,
                pointHoverRadius: 7
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: "index", intersect: false },
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: "#1e1e2e",
                    titleFont: { size: 12, weight: "700" },
                    bodyFont: { size: 12 },
                    padding: 10,
                    callbacks: {
                        label: function(ctx) {
                            return "  " + ctx.parsed.y + " students enrolled";
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: false,
                    ticks: { stepSize: 1, font: { size: 11 }, color: "#9CA3AF" },
                    grid: { color: "rgba(0,0,0,.04)" },
                    border: { display: false }
                },
                x: {
                    ticks: { font: { size: 11 }, color: "#9CA3AF" },
                    grid: { display: false },
                    border: { display: false }
                }
            }
        }
    });
</script>