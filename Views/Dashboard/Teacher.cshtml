@model MalikongkongNHS.Models.ViewModels.TeacherDashboardVM

@{
    ViewData["Title"] = "Teacher Dashboard";
}

<!-- ============================================ -->
<!-- STYLES                                       -->
<!-- ============================================ -->
<style>

/* HEADER */
.dashboard-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:1.5rem;
}
.page-title{
    font-size:2rem;
    font-weight:700;
    margin:0;
    color:#2C2C2C;
}
.date-badge{
    background:#fff;
    color:#C8102E;
    padding:6px 16px;
    border-radius:20px;
    font-size:.875rem;
    font-weight:600;
    border:1.5px solid rgba(200,16,46,.2);
    box-shadow:0 2px 6px rgba(200,16,46,.08);
}

/* STAT CARDS */
.stat-card{
    background:#fff;
    border-radius:16px;
    padding:1.4rem 1.8rem;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:1rem;
    box-shadow:0 2px 12px rgba(0,0,0,.07);
    transition:transform .2s ease, box-shadow .2s ease;
    border-left:4px solid transparent;
}
.stat-card:hover{
    transform:translateY(-3px);
    box-shadow:0 6px 20px rgba(0,0,0,.12);
}
.stat-card-1{ border-left-color:#C8102E; }
.stat-card-2{ border-left-color:#1565C0; }
.stat-card-3{ border-left-color:#2E7D32; }
.stat-card-4{ border-left-color:#6A1B9A; }

.stat-left{
    display:flex;
    flex-direction:column;
    align-items:flex-start;
    gap:.5rem;
}

.stat-icon{
    width:48px;
    height:48px;
    border-radius:12px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:1.4rem;
    flex-shrink:0;
}
.icon-red    { background:rgba(200,16,46,.10);  color:#C8102E; }
.icon-blue   { background:rgba(21,101,192,.10); color:#1565C0; }
.icon-green  { background:rgba(46,125,50,.10);  color:#2E7D32; }
.icon-purple { background:rgba(106,27,154,.10); color:#6A1B9A; }

.stat-label{
    font-size:.72rem;
    font-weight:700;
    text-transform:uppercase;
    letter-spacing:.6px;
    color:#9CA3AF;
    white-space:nowrap;
}

.stat-number{
    font-size:3.5rem;
    font-weight:900;
    line-height:1;
    color:#2C2C2C;
    letter-spacing:-2px;
    margin-left:auto;
    flex-shrink:0;
}

/* SECTION CARDS */
.section-card{
    background:#fff;
    border-radius:16px;
    padding:1.4rem 1.6rem;
    box-shadow:0 2px 12px rgba(0,0,0,.07);
    height:100%;
}
.section-card-title{
    font-size:.85rem;
    font-weight:700;
    text-transform:uppercase;
    letter-spacing:.6px;
    color:#6C757D;
    margin-bottom:1rem;
    display:flex;
    align-items:center;
    gap:.5rem;
}

/* ACTIVITY TABLE */
.activity-table th{
    font-size:.75rem;
    font-weight:600;
    text-transform:uppercase;
    letter-spacing:.5px;
    color:#9CA3AF;
    border-bottom:1.5px solid #F0F0F0;
    padding:8px 10px;
    background:transparent;
}
.activity-table td{
    font-size:.82rem;
    padding:9px 10px;
    vertical-align:middle;
    border-bottom:1px solid #F8F9FA;
    color:#374151;
}
.activity-table tbody tr:last-child td{
    border-bottom:none;
}
.activity-dot{
    width:8px;
    height:8px;
    border-radius:50%;
    display:inline-block;
    flex-shrink:0;
}

</style>

<!-- ============================================ -->
<!-- HEADER                                       -->
<!-- ============================================ -->
<div class="dashboard-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="text-muted mb-0">Welcome back, Teacher. Here's your class overview.</p>
    </div>
    <span class="date-badge">
        <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("MMMM dd, yyyy")
    </span>
</div>

<!-- ============================================ -->
<!-- STAT CARDS                                   -->
<!-- ============================================ -->
<div class="row g-3 mb-4">

    <!-- My Students -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card stat-card-1">
            <div class="stat-left">
                <div class="stat-icon icon-red">
                    <i class="bi bi-mortarboard-fill"></i>
                </div>
                <div class="stat-label">My Students</div>
            </div>
            <div class="stat-number">@Model.TotalStudentsHandled</div>
        </div>
    </div>

    <!-- My Classes -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card stat-card-2">
            <div class="stat-left">
                <div class="stat-icon icon-blue">
                    <i class="bi bi-easel-fill"></i>
                </div>
                <div class="stat-label">My Classes</div>
            </div>
            <div class="stat-number">@Model.TotalClasses</div>
        </div>
    </div>

    <!-- Attendance Today -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card stat-card-3">
            <div class="stat-left">
                <div class="stat-icon icon-green">
                    <i class="bi bi-calendar-check-fill"></i>
                </div>
                <div class="stat-label">Attendance Today</div>
            </div>
            <div class="stat-number">@Model.TodayAttendanceTaken</div>
        </div>
    </div>

    <!-- Pending Grades -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card stat-card-4">
            <div class="stat-left">
                <div class="stat-icon icon-purple">
                    <i class="bi bi-journal-text"></i>
                </div>
                <div class="stat-label">Pending Grades</div>
            </div>
            <div class="stat-number">@Model.PendingGrades</div>
        </div>
    </div>

</div>

<!-- ============================================ -->
<!-- BOTTOM ROW: LINE GRAPH + RECENT ACTIVITY     -->
<!-- ============================================ -->
<div class="row g-3">

    <!-- Attendance Line Graph -->
    <div class="col-xl-8">
        <div class="section-card">
            <div class="section-card-title">
                <i class="bi bi-graph-up-arrow text-success"></i>
                Attendance Overview — Last 7 Days
            </div>
            <canvas id="attendanceChart" height="110"></canvas>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="col-xl-4">
        <div class="section-card">
            <div class="section-card-title">
                <i class="bi bi-clock-history text-primary"></i>
                Recent Activity
            </div>
            <table class="table activity-table mb-0">
                <thead>
                    <tr>
                        <th>Activity</th>
                        <th>Time</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <span class="activity-dot bg-success"></span>
                                Attendance Recorded
                            </div>
                        </td>
                        <td class="text-muted">Today</td>
                        <td><span class="badge bg-success bg-opacity-10 text-success" style="font-size:.7rem">Done</span></td>
                    </tr>
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <span class="activity-dot bg-warning"></span>
                                Grades Pending
                            </div>
                        </td>
                        <td class="text-muted">Today</td>
                        <td><span class="badge bg-warning bg-opacity-10 text-warning" style="font-size:.7rem">@Model.PendingGrades pending</span></td>
                    </tr>
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <span class="activity-dot bg-primary"></span>
                                Classes Active
                            </div>
                        </td>
                        <td class="text-muted">Today</td>
                        <td><span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:.7rem">@Model.TotalClasses classes</span></td>
                    </tr>
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <span class="activity-dot" style="background:#C8102E"></span>
                                Students Handled
                            </div>
                        </td>
                        <td class="text-muted">Total</td>
                        <td><span class="badge bg-opacity-10" style="background:rgba(200,16,46,.1);color:#C8102E;font-size:.7rem">@Model.TotalStudentsHandled students</span></td>
                    </tr>
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <span class="activity-dot bg-secondary"></span>
                                System Login
                            </div>
                        </td>
                        <td class="text-muted">@DateTime.Now.ToString("hh:mm tt")</td>
                        <td><span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size:.7rem">Active</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- ============================================ -->
<!-- CHART.JS                                     -->
<!-- ============================================ -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
    const today = new Date();
    const labels = [];
    for (let i = 6; i >= 0; i--) {
        const d = new Date(today);
        d.setDate(d.getDate() - i);
        labels.push(d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }));
    }

    // Use today's real value from the model; mock the rest with plausible data
    const todayVal = @Model.TodayAttendanceTaken;
    const total    = @Model.TotalStudentsHandled;
    const base     = total > 0 ? total : 20;

    function rnd(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }
    const data = [
        rnd(Math.max(0, base - 5), base),
        rnd(Math.max(0, base - 4), base),
        rnd(Math.max(0, base - 6), base),
        rnd(Math.max(0, base - 3), base),
        rnd(Math.max(0, base - 5), base),
        rnd(Math.max(0, base - 4), base),
        todayVal
    ];

    const ctx = document.getElementById('attendanceChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Students Present',
                data: data,
                borderColor: '#C8102E',
                backgroundColor: 'rgba(200,16,46,0.08)',
                borderWidth: 2.5,
                pointBackgroundColor: '#C8102E',
                pointRadius: 5,
                pointHoverRadius: 7,
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#2C2C2C',
                    titleFont: { size: 12 },
                    bodyFont: { size: 13, weight: 'bold' },
                    padding: 10,
                    cornerRadius: 8
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: 'rgba(0,0,0,.05)' },
                    ticks: { precision: 0, font: { size: 11 } }
                },
                x: {
                    grid: { display: false },
                    ticks: { font: { size: 10 } }
                }
            }
        }
    });
})();
</script>
