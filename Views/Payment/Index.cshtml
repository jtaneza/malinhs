@{
    ViewData["Title"] = "Payments";
}

<style>
    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0;
        color: var(--primary);
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .stat-card small {
        color: #868e96;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-card h2 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
        color: var(--primary);
    }

    .card-icon {
        font-size: 2.5rem;
        color: var(--secondary);
        opacity: 0.3;
    }

    .section-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .nav-tabs .nav-link {
        color: var(--primary);
        font-weight: 500;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 10px 20px;
    }

    .nav-tabs .nav-link.active {
        color: var(--secondary);
        border-bottom: 3px solid var(--secondary);
        background: none;
    }

    .nav-tabs .nav-link:hover {
        color: var(--secondary);
        border-bottom: 3px solid var(--secondary);
    }

    .nav-tabs {
        border-bottom: 1px solid #dee2e6;
        margin-bottom: 1.5rem;
    }

    .badge-paid {
        background: #d1fae5;
        color: #065f46;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-pending {
        background: #fef3c7;
        color: #92400e;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-overdue {
        background: #fee2e2;
        color: #991b1b;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .receipt-box {
        border: 1px dashed #ccc;
        border-radius: 12px;
        padding: 2rem;
        max-width: 480px;
        margin: 0 auto;
        background: #fafafa;
    }

    .receipt-box h4 {
        text-align: center;
        font-weight: 700;
        color: var(--secondary);
    }

    .receipt-row {
        display: flex;
        justify-content: space-between;
        padding: 6px 0;
        border-bottom: 1px dashed #eee;
        font-size: 0.9rem;
    }

    @@media print {
        .no-print { display: none !important; }
        .receipt-box { border: 1px solid #000; }
    }
</style>

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">Payments</h1>
        <p class="text-muted">Manage all student fee payments and transactions.</p>
    </div>
    <button class="btn btn-danger no-print" data-bs-toggle="modal" data-bs-target="#newPaymentModal">
        <i class="bi bi-plus-lg me-1"></i> New Payment
    </button>
</div>

<!-- STAT CARDS -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div>
                <small>Total Revenue</small>
                <h2>₱0.00</h2>
            </div>
            <i class="bi bi-cash-stack card-icon"></i>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div>
                <small>Paid Students</small>
                <h2>0</h2>
            </div>
            <i class="bi bi-person-check-fill card-icon"></i>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div>
                <small>Pending Payments</small>
                <h2>0</h2>
            </div>
            <i class="bi bi-exclamation-circle-fill card-icon"></i>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div>
                <small>Revenue Today</small>
                <h2>₱0.00</h2>
            </div>
            <i class="bi bi-graph-up-arrow card-icon"></i>
        </div>
    </div>
</div>

<!-- TABS -->
<div class="section-card">
    <ul class="nav nav-tabs" id="paymentTabs">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#transactions">
                <i class="bi bi-arrow-left-right me-1"></i> Transactions
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#history">
                <i class="bi bi-clock-history me-1"></i> Payment History
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#receipt">
                <i class="bi bi-receipt me-1"></i> Print Receipt
            </a>
        </li>
    </ul>

    <div class="tab-content">

        <!-- TAB 1: TRANSACTIONS -->
        <div class="tab-pane fade show active" id="transactions">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <input type="text" class="form-control w-25" placeholder="Search student..." />
                <select class="form-select w-auto">
                    <option>All Status</option>
                    <option>Paid</option>
                    <option>Pending</option>
                    <option>Overdue</option>
                </select>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Student Name</th>
                            <th>Grade & Section</th>
                            <th>Fee Type</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                No transactions yet.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TAB 2: PAYMENT HISTORY -->
        <div class="tab-pane fade" id="history">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <input type="text" class="form-control w-25" placeholder="Search student..." />
                <div class="d-flex gap-2">
                    <input type="date" class="form-control" />
                    <input type="date" class="form-control" />
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Receipt #</th>
                            <th>Student Name</th>
                            <th>Fee Type</th>
                            <th>Amount Paid</th>
                            <th>Date Paid</th>
                            <th>Cashier</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-clock-history fs-3 d-block mb-2"></i>
                                No payment history yet.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TAB 3: PRINT RECEIPT -->
        <div class="tab-pane fade" id="receipt">
            <div class="row mb-4 no-print">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Search Student</label>
                    <input type="text" class="form-control" placeholder="Enter student name or ID..." />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button class="btn btn-danger w-100">
                        <i class="bi bi-search me-1"></i> Find Receipt
                    </button>
                </div>
            </div>

            <div class="receipt-box">
                <h4>Malikongkong NHS</h4>
                <p class="text-center text-muted mb-3" style="font-size:0.85rem;">Official Payment Receipt</p>
                <div class="receipt-row"><span>Receipt No.</span><span>#000001</span></div>
                <div class="receipt-row"><span>Student Name</span><span>—</span></div>
                <div class="receipt-row"><span>Grade & Section</span><span>—</span></div>
                <div class="receipt-row"><span>Fee Type</span><span>—</span></div>
                <div class="receipt-row"><span>Amount Paid</span><span>₱0.00</span></div>
                <div class="receipt-row"><span>Date</span><span>@DateTime.Now.ToString("MMMM dd, yyyy")</span></div>
                <div class="receipt-row"><span>Cashier</span><span>—</span></div>
                <div class="mt-3 text-center">
                    <button class="btn btn-outline-danger no-print" onclick="window.print()">
                        <i class="bi bi-printer me-1"></i> Print Receipt
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- NEW PAYMENT MODAL -->
@section Modals {
<div class="modal fade" id="newPaymentModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-cash-stack me-2 text-danger"></i>Record Payment
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Student Name</label>
                    <input type="text" class="form-control" placeholder="Search student..." />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Fee Type</label>
                    <select class="form-select">
                        <option>— Select Fee Type —</option>
                        <option>Tuition Fee</option>
                        <option>Miscellaneous Fee</option>
                        <option>Laboratory Fee</option>
                        <option>Other</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Amount</label>
                    <div class="input-group">
                        <span class="input-group-text">₱</span>
                        <input type="number" class="form-control" placeholder="0.00" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Date</label>
                    <input type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Notes (Optional)</label>
                    <textarea class="form-control" rows="2" placeholder="Additional notes..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger">
                    <i class="bi bi-check-lg me-1"></i> Save Payment
                </button>
            </div>
        </div>
    </div>
</div>
}
