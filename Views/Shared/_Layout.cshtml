@using Microsoft.AspNetCore.Http

@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();

    var role = Context.Session.GetString("Role");
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Malikongkong NHS SIS</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet" />

    <style>

.header-actions button,
.header-actions a{
    position: relative;
    z-index: 20;
    pointer-events: auto;
}

        :root{
    --primary:#2C2C2C;
    --secondary:#C8102E;
    --background:#F5F5F5;
    --white:#FFFFFF;
}

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            background:var(--background);
            overflow-x:hidden;
        }

        /* ================= HEADER ================= */

        .topbar{
            position:fixed;
            top:0;
            left:0;
            right:0;
            height:70px;
            background:#fff;
            display:flex;
            justify-content:space-between;
            align-items:center;
            padding:0 25px;
            box-shadow:0 2px 15px rgba(0,0,0,.08);
            z-index:1200;
        }

        .brand{
            display:flex;
            align-items:center;
            gap:15px;
        }

        .brand img{
            width:45px;
            height:45px;
            object-fit:contain;
        }

        .brand h5{
            margin:0;
            color:var(--primary);
            font-weight:700;
        }

        .header-right{
            display:flex;
            align-items:center;
            gap:10px;
        }

        .profile-btn{
    border:none;
    background:#F5F5F5;
    border-radius:10px;
    padding:8px 15px;
    color:#2C2C2C;
}

        .menu-btn{
            display:none;
            border:none;
            background:none;
            font-size:28px;
            color:var(--primary);
        }

        /* ================= SIDEBAR ================= */

        .sidebar{
    position:fixed;
    top:70px;
    left:0;
    width:260px;
    height:calc(100vh - 70px);
    background:#2C2C2C;
    display:flex;
    flex-direction:column;
    z-index:1100;
    transition:.3s;
    box-shadow:3px 0 15px rgba(0,0,0,.08);
}

        .sidebar-menu{
            flex:1;
            overflow-y:auto;
            padding-top:10px;
        }

        .sidebar-bottom{
            border-top:1px solid rgba(255,255,255,.15);
        }

        .sidebar a{
    display:flex;
    align-items:center;
    gap:12px;
    padding:15px 25px;
    color:#ffffff;
    text-decoration:none;
    transition:.3s;
    font-weight:500;
    border-left:4px solid transparent;
}

        .sidebar a:hover{
    background:#C8102E;
    color:#fff;
    border-left:4px solid #ffffff;
}

        .sidebar a.active{
    background:#C8102E;
    color:#fff;
    border-left:4px solid #ffffff;
}

        .sidebar i{
            font-size:18px;
        }

        /* ================= LOGOUT BUTTON ================= */

        .logout-btn{
            width:100%;
            background:none;
            border:none;
            color:#fff;
            padding:15px 25px;
            display:flex;
            align-items:center;
            gap:12px;
            cursor:pointer;
            transition:.3s;
            font-weight:500;
        }

        .logout-btn:hover{
    background:#C8102E;
}
        .logout-btn i{
            font-size:18px;
        }
        /* ================= CONTENT LAYER FIX ================= */

        /* ================= PAGE HEADER BUTTONS ================= */
        .page-header,
.header-actions{
    position: relative;
    z-index: 10;
}

        /* ================= MODAL FIX (CRITICAL) ================= */
        .modal{
            z-index: 2000 !important;
        }

        .modal-backdrop{
            z-index: 1990 !important;
        }

        /* ================= BUTTON CLICK FIX ================= */
        .header-actions button,
        .header-actions a{
            pointer-events: auto !important;
        }

        /* ================= SIDEBAR SAFETY ================= */
        .sidebar{
            z-index: 1100;
        }
        /* ================= CONTENT ================= */

        .content{
            margin-top:70px;
            margin-left:260px;
            width:calc(100% - 260px);
            min-height:100vh;
            padding:30px;
        }

        /* ================= OVERLAY ================= */

.overlay{
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 1000;
}

.overlay.show{
    display: block;
}

.modal{
    z-index: 2000 !important;
}

.modal-backdrop{
    z-index: 1990 !important;
}
  /* ================= MOBILE ================= */

        @@media (max-width:992px){

            .menu-btn{
                display:block;
            }

            .sidebar{
                transform:translateX(-100%);
            }

            .sidebar.show{
                transform:translateX(0);
            }

            .content{
                margin-left:0;
                width:100%;
                padding:20px;
            }

           .brand h5{
    margin:0;
    color:#2C2C2C;
    font-weight:700;
}
        }

        @@media (max-width:576px){

            .topbar{
                padding:0 15px;
            }

            .brand h5{
                font-size:13px;
            }

            .content{
                padding:15px;
            }
        }
#overlay {
    display: none !important;
    pointer-events: none;
}
    </style>

</head>
<body>

<div class="overlay" id="overlay"></div>

<header class="topbar">

    <div class="d-flex align-items-center gap-3">

        <button class="menu-btn" id="menuBtn">
            <i class="bi bi-list"></i>
        </button>

        <div class="brand">
            <img src="~/images/logo.png" alt="Logo" />
            <h5>Malikongkong NHS SErpS</h5>
        </div>

    </div>

    <div class="header-right">

        <button class="btn btn-light">
            <i class="bi bi-bell"></i>
        </button>

<button class="profile-btn">
    <i class="bi bi-person-circle"></i>
    @Context.Session.GetString("Role")
</button>

    </div>

</header>

<nav class="sidebar" id="sidebar">

<div class="sidebar-menu">

    @if (role == "Admin")
    {
        <a asp-controller="Dashboard" asp-action="Index"
           class="@(currentController == "Dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i>
            <span>Dashboard</span>
        </a>

        <a asp-controller="Student" asp-action="Index"
           class="@(currentController == "Student" ? "active" : "")">
            <i class="bi bi-mortarboard"></i>
            <span>Students</span>
        </a>

        <a asp-controller="Teacher" asp-action="Index"
           class="@(currentController == "Teacher" ? "active" : "")">
            <i class="bi bi-person-workspace"></i>
            <span>Teachers</span>
        </a>

        <a asp-controller="Section" asp-action="Index"
           class="@(currentController == "Section" ? "active" : "")">
            <i class="bi bi-building"></i>
            <span>Classes & Sections</span>
        </a>

        <a asp-controller="Payment" asp-action="Index"
           class="@(currentController == "Payment" ? "active" : "")">
            <i class="bi bi-cash-stack"></i>
            <span>Payments</span>
        </a>

        <a asp-controller="Report" asp-action="Index"
           class="@(currentController == "Report" ? "active" : "")">
            <i class="bi bi-bar-chart-line"></i>
            <span>Reports</span>
        </a>

        <a asp-controller="User" asp-action="Index"
           class="@(currentController == "User" ? "active" : "")">
            <i class="bi bi-people"></i>
            <span>Users</span>
        </a>
    }

    @if (role == "Teacher")
{
    <a asp-controller="Dashboard" asp-action="Teacher"
       class="@(currentController == "Dashboard" ? "active" : "")">
        <i class="bi bi-speedometer2"></i>
        <span>Dashboard</span>
    </a>

    <a asp-controller="Class" asp-action="Index"
       class="@(currentController == "Class" ? "active" : "")">
        <i class="bi bi-easel2-fill"></i>
        <span>My Classes</span>
    </a>

    <!-- ADD THIS ↓ -->
    <a asp-controller="Schedule" asp-action="Index"
       class="@(currentController == "Schedule" ? "active" : "")">
        <i class="bi bi-calendar-week-fill"></i>
        <span>My Schedule</span>
    </a>

    <a asp-controller="Attendance" asp-action="Index"
       class="@(currentController == "Attendance" ? "active" : "")">
        <i class="bi bi-calendar-check"></i>
        <span>Attendance</span>
    </a>

    <a asp-controller="Grade" asp-action="Index"
       class="@(currentController == "Grade" ? "active" : "")">
        <i class="bi bi-journal-text"></i>
        <span>Grades</span>
    </a>

    <a asp-controller="Report" asp-action="Index"
       class="@(currentController == "Report" ? "active" : "")">
        <i class="bi bi-bar-chart-line"></i>
        <span>Reports</span>
    </a>
}

    @if (role == "Cashier")
    {
        <a asp-controller="Payment" asp-action="Index"
           class="@(currentController == "Payment" ? "active" : "")">
            <i class="bi bi-cash-stack"></i>
            <span>Payments</span>
        </a>
    }

    @if (role == "Student")
    {
        <a asp-controller="Dashboard" asp-action="Student"
           class="@(currentController == "Dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i>
            <span>Dashboard</span>
        </a>

        <a asp-controller="Student" asp-action="Profile"
           class="@(currentController == "Student" ? "active" : "")">
            <i class="bi bi-person"></i>
            <span>My Profile</span>
        </a>

        
        <a asp-controller="Attendance" asp-action="StudentView"
           class="@(currentController == "Attendance" ? "active" : "")">
            <i class="bi bi-calendar-check"></i>
            <span>My Attendance</span>
        </a>

        
        <a asp-controller="Grade" asp-action="StudentView"
           class="@(currentController == "Grade" ? "active" : "")">
            <i class="bi bi-journal-text"></i>
            <span>My Grades</span>
        </a>
    }

</div>
    <div class="sidebar-bottom">

        <form asp-controller="Account"
              asp-action="Logout"
              method="post">

            <button type="submit" class="logout-btn">

                <i class="bi bi-box-arrow-right"></i>
                <span>Logout</span>

            </button>

        </form>

    </div>

</nav>

<main class="content">
    @RenderBody()
</main>

@RenderSection("Modals", required: false)

<script>

    const menuBtn = document.getElementById("menuBtn");
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("overlay");

    menuBtn?.addEventListener("click", () => {

        sidebar.classList.toggle("show");
        overlay.classList.toggle("show");

    });

    overlay?.addEventListener("click", () => {

        sidebar.classList.remove("show");
        overlay.classList.remove("show");

    });

</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
