@model List<MalikongkongNHS.Models.Entities.Student>

@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h1 class="page-title">Students</h1>
        <p class="page-subtitle">Manage student records</p>
    </div>

    <a asp-controller="Student"
       asp-action="Create"
       class="btn btn-add">

        <i class="bi bi-plus-circle"></i>
        Add Student

    </a>

</div>

<div class="custom-card">

    <div class="card-body">

        <!-- SEARCH -->
        <div class="row mb-3">

            <div class="col-md-4">
                <input type="text"
                       id="studentSearch"
                       class="form-control search-box"
                       placeholder="Search Student..." />
            </div>

        </div>

        <!-- TABLE -->
        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead class="table-light">
                    <tr>
                        <th>LRN</th>
                        <th>Name</th>
                        <th>Gender</th>
                        <th>Section</th>
                        <th>Status</th>
                        <th width="180">Actions</th>
                    </tr>
                </thead>

                <tbody id="studentTable">

                    @if (Model != null && Model.Any())
                    {
                        foreach (var student in Model)
                        {
                            <tr>

                                <td>@student.LRN</td>

                                <td>
                                    @student.LastName, @student.FirstName
                                </td>

                                <td>@student.Gender</td>

                                <td>
                                    @(student.Section?.SectionName ?? "No Section")
                                </td>

                                <td>
                                    @if (student.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>

                                <td class="actions-cell">

                                    <a asp-controller="Student"
                                       asp-action="Edit"
                                       asp-route-id="@student.StudentId"
                                       class="btn btn-sm btn-primary">

                                        <i class="bi bi-pencil-square"></i>
                                        Edit
                                    </a>

                                    <form asp-controller="Student"
                                          asp-action="Delete"
                                          asp-route-id="@student.StudentId"
                                          method="post"
                                          class="d-inline">

                                        <button type="submit"
                                                class="btn btn-sm btn-danger"
                                                onclick="return confirm('Delete this student?')">

                                            <i class="bi bi-trash"></i>
                                            Delete
                                        </button>

                                    </form>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6"
                                class="text-center text-muted py-5">
                                No student records found.
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<!-- STYLE -->
<style>

.page-title{
    color:#2C2C2C;
    font-size:3rem;
    font-weight:700;
    margin-bottom:0;
}

.page-subtitle{
    color:#6C757D;
    font-size:1rem;
    margin-top:5px;
}

.custom-card{
    background:#FFFFFF;
    border:none;
    border-radius:16px;
    overflow:visible;
    box-shadow:0 4px 12px rgba(0,0,0,.08);
}

/* BUTTON */
.btn-add{
    background:#C8102E;
    color:#FFFFFF;
    border:none;
    padding:10px 18px;
    border-radius:10px;
    font-weight:600;
}

.btn-add:hover{
    background:#A50D25;
    color:#FFFFFF;
}

/* TABLE */
.table{
    margin-bottom:0;
}

.table thead th{
    border-bottom:2px solid #E9ECEF;
    color:#2C2C2C;
    font-weight:600;
}

.table tbody td{
    vertical-align:middle;
}

/* INPUT */
.search-box{
    border-radius:10px;
    border:1px solid #DEE2E6;
}

.search-box:focus{
    border-color:#2C2C2C;
    box-shadow:0 0 0 3px rgba(44,44,44,.10);
}

/* ACTION BUTTONS */
.btn-primary{
    background:#2C2C2C;
    border-color:#2C2C2C;
}

.btn-primary:hover{
    background:#1F1F1F;
}

.btn-danger{
    background:#C8102E;
    border-color:#C8102E;
}

.btn-danger:hover{
    background:#A50D25;
}

/* RESPONSIVE */
@@media(max-width:768px){

    .page-title{
        font-size:2rem;
    }

    .btn-add{
        margin-top:10px;
    }
}

</style>

<!-- SEARCH SCRIPT -->
<script>
document.getElementById("studentSearch").addEventListener("keyup", function () {

    let value = this.value.toLowerCase();
    let rows = document.querySelectorAll("#studentTable tr");

    rows.forEach(row => {

        let text = row.innerText.toLowerCase();
        row.style.display = text.includes(value) ? "" : "none";

    });

});
</script>