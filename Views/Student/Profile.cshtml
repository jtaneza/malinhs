@using Microsoft.AspNetCore.Http
@model MalikongkongNHS.Models.Entities.Student

@{
    ViewData["Title"] = "My Profile";
    var fullName = $"{Model.FirstName} {Model.MiddleName} {Model.LastName}".Replace("  ", " ").Trim();
    var initials = $"{Model.FirstName?.FirstOrDefault()}{Model.LastName?.FirstOrDefault()}".ToUpper();
}

<style>
.prof-title { font-size:2rem; font-weight:700; color:#2C2C2C; margin:0; }
.date-badge {
    background:#fff; color:#C8102E; padding:6px 16px; border-radius:20px;
    font-size:.875rem; font-weight:600; border:1.5px solid rgba(200,16,46,.2);
}

/* ── HERO ── */
.hero-card { background:#fff; border-radius:20px; box-shadow:0 2px 16px rgba(0,0,0,.08); overflow:hidden; margin-bottom:1.5rem; }
.hero-banner { height:110px; background:linear-gradient(135deg,#C8102E 0%,#8B0000 60%,#2C2C2C 100%); }
.hero-body { padding:0 2rem 1.8rem; }

/* ── AVATAR ── */
.avatar-wrap { position:relative; display:inline-block; margin-top:-52px; margin-bottom:.8rem; }
.avatar-circle {
    width:104px; height:104px; border-radius:50%; border:4px solid #fff;
    box-shadow:0 4px 16px rgba(0,0,0,.18); object-fit:cover;
    background:#2C2C2C; color:#fff; font-size:2.4rem; font-weight:700;
    display:flex; align-items:center; justify-content:center;
    cursor:pointer; overflow:hidden; position:relative;
}
.avatar-circle img { width:100%; height:100%; object-fit:cover; border-radius:50%; display:block; }
.avatar-overlay {
    position:absolute; inset:0; border-radius:50%;
    background:rgba(0,0,0,.45); color:#fff;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    font-size:.62rem; font-weight:600; opacity:0; transition:opacity .2s; cursor:pointer; gap:3px;
}
.avatar-wrap:hover .avatar-overlay { opacity:1; }
.avatar-overlay i { font-size:1.3rem; }
#photoInput { display:none; }

/* ── HERO BADGES ── */
.hero-name { font-size:1.45rem; font-weight:800; color:#2C2C2C; margin:0; line-height:1.2; }
.hero-sub  { font-size:.82rem; color:#6C757D; margin-top:2px; }
.hero-badges { display:flex; flex-wrap:wrap; gap:6px; margin-top:.6rem; }
.hbadge { display:inline-flex; align-items:center; gap:5px; font-size:.72rem; font-weight:600; border-radius:20px; padding:4px 11px; }
.hbadge-red   { background:rgba(200,16,46,.1);  color:#C8102E; }
.hbadge-blue  { background:rgba(21,101,192,.1); color:#1565C0; }
.hbadge-green { background:rgba(46,125,50,.1);  color:#2E7D32; }
.hbadge-gray  { background:#F3F4F6; color:#4B5563; }

/* ── INFO CARDS ── */
.info-card { background:#fff; border-radius:16px; box-shadow:0 2px 12px rgba(0,0,0,.07); padding:1.4rem 1.6rem; height:100%; }
.info-card-title {
    font-size:.72rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.6px; color:#9CA3AF; margin-bottom:1.1rem;
    display:flex; align-items:center; gap:7px;
}
.field-row { display:flex; align-items:flex-start; gap:10px; padding:.7rem 0; border-bottom:1px solid #F3F4F6; }
.field-row:last-child { border-bottom:none; }
.field-icon { width:34px; height:34px; border-radius:9px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:.95rem; }
.fi-red   { background:rgba(200,16,46,.08); color:#C8102E; }
.fi-blue  { background:rgba(21,101,192,.08); color:#1565C0; }
.fi-green { background:rgba(46,125,50,.08);  color:#2E7D32; }
.fi-gray  { background:#F3F4F6; color:#6C757D; }
.fi-purp  { background:rgba(106,27,154,.08); color:#6A1B9A; }
.field-label { font-size:.69rem; font-weight:600; text-transform:uppercase; letter-spacing:.4px; color:#9CA3AF; line-height:1; }
.field-value { font-size:.88rem; color:#2C2C2C; font-weight:500; margin-top:2px; }
.field-value.mono { font-family:monospace; letter-spacing:.5px; font-size:.9rem; }

/* ── CREDENTIALS CARD ── */
.cred-card {
    background:linear-gradient(135deg,#1a1a2e 0%,#2C2C2C 100%);
    border-radius:16px; padding:1.4rem 1.6rem;
    box-shadow:0 4px 20px rgba(0,0,0,.2); color:#fff; height:100%;
}
.cred-card-title { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.6px; color:rgba(255,255,255,.5); margin-bottom:1.1rem; display:flex; align-items:center; gap:7px; }
.cred-field-row { display:flex; align-items:flex-start; gap:10px; padding:.7rem 0; border-bottom:1px solid rgba(255,255,255,.08); }
.cred-field-row:last-child { border-bottom:none; }
.cred-icon { width:34px; height:34px; border-radius:9px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:.95rem; background:rgba(255,255,255,.1); color:#fff; }
.cred-label { font-size:.69rem; font-weight:600; text-transform:uppercase; letter-spacing:.4px; color:rgba(255,255,255,.45); line-height:1; }
.cred-value { font-size:.88rem; color:#fff; font-weight:500; margin-top:2px; }
.cred-value.mono { font-family:monospace; letter-spacing:1px; }
.pass-wrap { display:flex; align-items:center; gap:8px; }
.pass-toggle { background:rgba(255,255,255,.12); border:none; color:#fff; border-radius:6px; padding:2px 8px; font-size:.75rem; cursor:pointer; transition:.15s; }
.pass-toggle:hover { background:rgba(255,255,255,.2); }

/* ── STATUS ── */
.status-pill { display:inline-flex; align-items:center; gap:5px; font-size:.72rem; font-weight:700; border-radius:20px; padding:4px 12px; }
.sp-active   { background:rgba(25,135,84,.1); color:#198754; }
.sp-inactive { background:rgba(200,16,46,.1); color:#C8102E; }

/* ── MODALS ── */
.modal-content { border-radius:16px; border:none; }
.modal-header  { border-bottom:1px solid #F3F4F6; padding:1.2rem 1.5rem; }
.modal-footer  { border-top:1px solid #F3F4F6; padding:1rem 1.5rem; }
.btn-save   { background:#C8102E; color:#fff; border:none; border-radius:10px; padding:8px 22px; font-weight:600; transition:.2s; }
.btn-save:hover { background:#A50D25; color:#fff; }
.btn-cancel { background:#F3F4F6; color:#2C2C2C; border:none; border-radius:10px; padding:8px 18px; font-weight:600; }
.form-control:focus { border-color:#C8102E; box-shadow:0 0 0 3px rgba(200,16,46,.1); }

/* ── EDIT BUTTON on field rows ── */
.btn-edit-profile {
    background:#1565C0; color:#fff; border:none; border-radius:10px;
    padding:7px 18px; font-size:.82rem; font-weight:600;
    display:inline-flex; align-items:center; gap:6px; transition:.2s;
}
.btn-edit-profile:hover { background:#0D47A1; color:#fff; }
</style>

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="prof-title">My Profile</h1>
        <p class="text-muted mb-0">View and manage your personal information.</p>
    </div>
    <span class="date-badge"><i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("MMMM dd, yyyy")</span>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 mb-4">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- HERO CARD -->
<div class="hero-card">
    <div class="hero-banner"></div>
    <div class="hero-body">
        <div class="d-flex flex-wrap align-items-end gap-3">

            <div class="avatar-wrap" onclick="document.getElementById('photoInput').click()" title="Change profile photo">
                <div class="avatar-circle" id="avatarCircle">
                    <span id="avatarInitials">@initials</span>
                    <img src="" alt="" id="avatarImg" style="display:none;" />
                    <div class="avatar-overlay">
                        <i class="bi bi-camera-fill"></i>
                        <span>Change Photo</span>
                    </div>
                </div>
                <input type="file" id="photoInput" accept="image/*" />
            </div>

            <div style="flex:1; min-width:200px;">
                <p class="hero-name">@fullName</p>
                <p class="hero-sub">@(Model.Email ?? "No email on record")</p>
                <div class="hero-badges">
                    <span class="hbadge hbadge-red"><i class="bi bi-mortarboard-fill"></i> @(Model.Section?.GradeLevel ?? "No Grade")</span>
                    <span class="hbadge hbadge-blue"><i class="bi bi-building"></i> @(Model.Section?.SectionName ?? "No Section")</span>
                    @if (Model.IsActive)
                    {
                        <span class="hbadge hbadge-green"><i class="bi bi-check-circle-fill"></i> Active</span>
                    }
                    else
                    {
                        <span class="hbadge hbadge-red"><i class="bi bi-x-circle-fill"></i> Inactive</span>
                    }
                </div>
            </div>

            <div class="ms-auto d-flex gap-2 flex-wrap">
                <button class="btn-edit-profile" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                    <i class="bi bi-pencil-fill"></i> Edit Profile
                </button>
                <button class="btn-save" data-bs-toggle="modal" data-bs-target="#changePassModal">
                    <i class="bi bi-key-fill me-1"></i> Change Password
                </button>
            </div>
        </div>
    </div>
</div>

<!-- INFO SECTIONS -->
<div class="row g-3">

    <!-- Personal Information -->
    <div class="col-lg-6">
        <div class="info-card">
            <div class="info-card-title"><i class="bi bi-person-fill" style="color:#C8102E;"></i> Personal Information</div>

            <div class="field-row">
                <div class="field-icon fi-red"><i class="bi bi-person-fill"></i></div>
                <div><div class="field-label">Full Name</div><div class="field-value">@fullName</div></div>
            </div>
            <div class="field-row">
                <div class="field-icon fi-purp"><i class="bi bi-gender-ambiguous"></i></div>
                <div><div class="field-label">Gender</div><div class="field-value">@(Model.Gender ?? "—")</div></div>
            </div>
            <div class="field-row">
                <div class="field-icon fi-gray"><i class="bi bi-geo-alt-fill"></i></div>
                <div><div class="field-label">Address</div><div class="field-value">@(Model.Address ?? "—")</div></div>
            </div>
            <div class="field-row">
                <div class="field-icon fi-green"><i class="bi bi-telephone-fill"></i></div>
                <div><div class="field-label">Contact Number</div><div class="field-value">@(Model.ContactNumber ?? "—")</div></div>
            </div>
            <div class="field-row">
                <div class="field-icon fi-blue"><i class="bi bi-people-fill"></i></div>
                <div><div class="field-label">Guardian Name</div><div class="field-value">@(Model.GuardianName ?? "—")</div></div>
            </div>
        </div>
    </div>

    <!-- Academic Information -->
    <div class="col-lg-6">
        <div class="info-card">
            <div class="info-card-title"><i class="bi bi-mortarboard-fill" style="color:#1565C0;"></i> Academic Information</div>

            <div class="field-row">
                <div class="field-icon fi-blue"><i class="bi bi-upc-scan"></i></div>
                <div><div class="field-label">LRN (Learner Reference Number)</div><div class="field-value mono">@(Model.LRN ?? "—")</div></div>
            </div>
            <div class="field-row">
                <div class="field-icon fi-green"><i class="bi bi-mortarboard-fill"></i></div>
                <div><div class="field-label">Grade Level</div><div class="field-value">@(Model.Section?.GradeLevel ?? "Not Assigned")</div></div>
            </div>
            <div class="field-row">
                <div class="field-icon fi-gray"><i class="bi bi-building"></i></div>
                <div><div class="field-label">Section</div><div class="field-value">@(Model.Section?.SectionName ?? "Not Assigned")</div></div>
            </div>
            <div class="field-row">
                <div class="field-icon fi-green"><i class="bi bi-check-circle-fill"></i></div>
                <div>
                    <div class="field-label">Account Status</div>
                    <div class="field-value">
                        @if (Model.IsActive)
                        { <span class="status-pill sp-active"><i class="bi bi-circle-fill" style="font-size:.5rem;"></i> Active</span> }
                        else
                        { <span class="status-pill sp-inactive"><i class="bi bi-circle-fill" style="font-size:.5rem;"></i> Inactive</span> }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Credentials Card -->
    <div class="col-12">
        <div class="cred-card">
            <div class="cred-card-title"><i class="bi bi-shield-lock-fill"></i> Account Credentials</div>
            <div class="row g-0">
                <div class="col-md-6">
                    <div class="cred-field-row" style="padding-right:2rem;">
                        <div class="cred-icon"><i class="bi bi-envelope-fill"></i></div>
                        <div>
                            <div class="cred-label">Email / Username</div>
                            <div class="cred-value">@(Model.Email ?? "—")</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="cred-field-row">
                        <div class="cred-icon"><i class="bi bi-key-fill"></i></div>
                        <div style="flex:1;">
                            <div class="cred-label">Password</div>
                            <div class="pass-wrap">
                                <div class="cred-value mono" id="passDisplay">••••••••</div>
                                <button class="pass-toggle" id="passToggle" onclick="togglePass()">
                                    <i class="bi bi-eye" id="passIcon"></i> Show
                                </button>
                                <button class="pass-toggle" data-bs-toggle="modal" data-bs-target="#changePassModal">
                                    <i class="bi bi-pencil-fill"></i> Change
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== EDIT PROFILE MODAL ===== -->
@section Modals {
<div class="modal fade" id="editProfileModal" tabindex="-1" aria-labelledby="editProfileLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:500px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editProfileLabel" style="font-weight:700;">
                    <i class="bi bi-pencil-fill me-2" style="color:#1565C0;"></i>Edit Profile
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Student" asp-action="UpdateProfile" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="StudentId" value="@Model.StudentId" />
                <div class="modal-body" style="padding:1.4rem 1.5rem;">

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Email / Username</label>
                        <input type="email" name="Email" class="form-control"
                               value="@Model.Email" placeholder="Enter email" />
                        <div class="form-text">This is also your login username.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Contact Number</label>
                        <input type="text" name="ContactNumber" class="form-control"
                               value="@Model.ContactNumber" placeholder="e.g. 09123456789" maxlength="20" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Address</label>
                        <textarea name="Address" class="form-control" rows="2"
                                  placeholder="Enter your address">@Model.Address</textarea>
                    </div>

                    <div class="mb-1">
                        <label class="form-label fw-semibold small">Guardian Name</label>
                        <input type="text" name="GuardianName" class="form-control"
                               value="@Model.GuardianName" placeholder="Enter guardian name" />
                    </div>

                    <div class="form-text mt-2">
                        <i class="bi bi-info-circle me-1"></i>
                        Name, LRN, grade, and section can only be changed by an administrator.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-save">
                        <i class="bi bi-check-lg me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ===== CHANGE PASSWORD MODAL ===== -->
<div class="modal fade" id="changePassModal" tabindex="-1" aria-labelledby="changePassLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:440px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-700" id="changePassLabel" style="font-weight:700;">
                    <i class="bi bi-key-fill me-2" style="color:#C8102E;"></i>Change Password
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Student" asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="StudentId" value="@Model.StudentId" />
                <div class="modal-body" style="padding:1.4rem 1.5rem;">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Current Password</label>
                        <div class="input-group">
                            <input type="password" name="CurrentPassword" id="currPass"
                                   class="form-control" placeholder="Enter current password" required />
                            <button type="button" class="btn btn-outline-secondary"
                                    onclick="toggleField('currPass','currPassIcon')">
                                <i class="bi bi-eye" id="currPassIcon"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">New Password</label>
                        <div class="input-group">
                            <input type="password" name="NewPassword" id="newPass"
                                   class="form-control" placeholder="Enter new password" required minlength="6" />
                            <button type="button" class="btn btn-outline-secondary"
                                    onclick="toggleField('newPass','newPassIcon')">
                                <i class="bi bi-eye" id="newPassIcon"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-1">
                        <label class="form-label fw-semibold small">Confirm New Password</label>
                        <div class="input-group">
                            <input type="password" name="ConfirmPassword" id="confPass"
                                   class="form-control" placeholder="Confirm new password" required minlength="6" />
                            <button type="button" class="btn btn-outline-secondary"
                                    onclick="toggleField('confPass','confPassIcon')">
                                <i class="bi bi-eye" id="confPassIcon"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-save">
                        <i class="bi bi-check-lg me-1"></i> Update Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
}

@section Scripts {
<script>
const realPass = '@Html.Raw(Model.Password?.Replace("'", "\\'") ?? "")';
let passVisible = false;

function togglePass() {
    passVisible = !passVisible;
    const display = document.getElementById('passDisplay');
    const btn     = document.getElementById('passToggle');
    display.textContent = passVisible ? (realPass || '—') : '••••••••';
    btn.innerHTML = passVisible
        ? '<i class="bi bi-eye-slash" id="passIcon"></i> Hide'
        : '<i class="bi bi-eye" id="passIcon"></i> Show';
}

function toggleField(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon  = document.getElementById(iconId);
    if (input.type === 'password') { input.type = 'text';     icon.className = 'bi bi-eye-slash'; }
    else                           { input.type = 'password'; icon.className = 'bi bi-eye'; }
}

// Profile photo picker (localStorage)
const storageKey     = 'profilePhoto_student_@Model.StudentId';
const avatarImg      = document.getElementById('avatarImg');
const avatarInitials = document.getElementById('avatarInitials');
const saved          = localStorage.getItem(storageKey);
if (saved) {
    avatarImg.src = saved;
    avatarImg.style.display = 'block';
    if (avatarInitials) avatarInitials.style.display = 'none';
}
document.getElementById('photoInput').addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) { alert('Image must be under 5MB.'); return; }
    const reader = new FileReader();
    reader.onload = e => {
        avatarImg.src = e.target.result;
        avatarImg.style.display = 'block';
        if (avatarInitials) avatarInitials.style.display = 'none';
        localStorage.setItem(storageKey, e.target.result);
    };
    reader.readAsDataURL(file);
});

// Auto-dismiss alerts
setTimeout(() => {
    document.querySelectorAll('.alert').forEach(a => bootstrap.Alert.getOrCreateInstance(a)?.close());
}, 4000);
</script>
}
