@model List<MalikongkongNHS.Models.ViewModels.UserM>

@{
    ViewData["Title"] = "Users";
}

<style>
    /* ── Typography — targeted, not blanket bold ── */
    .users-page,
    .users-page table,
    .users-page input,
    .users-page button,
    .users-page select,
    .users-page textarea {
        font-family: "Segoe UI", Arial, sans-serif;
        font-weight: 400;
    }

    /* Page header */
    .page-title {
        color: #1a1a2e;
        font-size: 2.4rem;
        font-weight: 800;
        letter-spacing: -.5px;
        margin-bottom: 0;
        line-height: 1.1;
    }
    .page-subtitle {
        color: #9CA3AF;
        font-size: .88rem;
        font-weight: 400;
        margin-top: 4px;
    }

    /* Add button */
    .btn-add {
        background: #C8102E;
        color: #fff;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: .875rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
        transition: background .2s, transform .15s, box-shadow .2s;
        box-shadow: 0 4px 12px rgba(200,16,46,.3);
        text-decoration: none;
    }
    .btn-add:hover {
        background: #a50d25;
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(200,16,46,.35);
    }

    /* Card */
    .custom-card {
        background: #fff;
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,.07);
        padding: 1.5rem;
    }

    /* Search */
    .search-box {
        border-radius: 10px;
        border: 1.5px solid #E5E7EB;
        padding: 9px 14px 9px 36px;
        font-size: .875rem;
        font-weight: 400;
        color: #374151;
        transition: border-color .2s, box-shadow .2s;
        outline: none;
        width: 100%;
        background: #FAFAFA;
    }
    .search-box::placeholder { color: #B0B7C3; }
    .search-box:focus {
        border-color: #C8102E;
        box-shadow: 0 0 0 3px rgba(200,16,46,.10);
        background: #fff;
    }
    .search-wrap { position: relative; }
    .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #B0B7C3;
        font-size: .82rem;
        pointer-events: none;
    }

    /* Table */
    .users-table { width: 100%; border-collapse: collapse; }
    .users-table thead tr { border-bottom: 2px solid #F3F4F6; }
    .users-table thead th {
        font-size: .70rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #B0B7C3;
        padding: 10px 16px;
        background: transparent;
        white-space: nowrap;
    }
    .users-table tbody tr {
        border-bottom: 1px solid #F9FAFB;
        transition: background .13s;
    }
    .users-table tbody tr:hover { background: #FFF5F7; }
    .users-table tbody tr:last-child { border-bottom: none; }
    .users-table td {
        padding: 14px 16px;
        font-size: .875rem;
        font-weight: 400;
        color: #374151;
        vertical-align: middle;
    }

    /* User ID chip */
    .uid-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px; height: 32px;
        border-radius: 8px;
        background: #F3F4F6;
        color: #6B7280;
        font-size: .78rem;
        font-weight: 700;
    }

    /* Full name */
    .user-fullname {
        font-weight: 600;
        color: #111827;
        font-size: .9rem;
    }

    /* Username */
    .user-username {
        font-size: .82rem;
        color: #6B7280;
        font-weight: 400;
    }

    /* Role badge */
    .role-badge {
        display: inline-block;
        padding: 3px 12px;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .04em;
        text-transform: uppercase;
    }
    .role-admin   { background: rgba(200,16,46,.10);  color: #C8102E; }
    .role-cashier { background: rgba(21,101,192,.10); color: #1565C0; }
    .role-teacher { background: rgba(46,125,50,.10);  color: #2E7D32; }
    .role-student { background: rgba(217,119,6,.10);  color: #D97706; }

    /* Password mask */
    .pwd-mask {
        color: #C8102E;
        font-size: 1.1rem;
        letter-spacing: 3px;
        font-weight: 900;
    }

    /* Action buttons */
    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 13px;
        border-radius: 7px;
        font-size: .75rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: opacity .15s, transform .12s;
        white-space: nowrap;
    }
    .btn-action:hover { opacity: .82; transform: translateY(-1px); }
    .btn-view   { background: #EFF6FF; color: #1565C0; }
    .btn-edit   { background: #FFFBEB; color: #B45309; }
    .btn-delete { background: #FFF1F2; color: #C8102E; }
    .actions-cell { display: flex; gap: 6px; align-items: center; }

    /* Modal */
    .modal-content {
        border-radius: 18px;
        border: none;
        box-shadow: 0 24px 64px rgba(0,0,0,.18);
        overflow: hidden;
    }
    .modal-header {
        background: #fff;
        border-bottom: 1.5px solid #F3F4F6;
        padding: 1.2rem 1.5rem;
    }
    .modal-title-text {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .modal-body { padding: 1.4rem 1.5rem; background: #fff; }
    .modal-footer {
        background: #FAFAFA;
        border-top: 1.5px solid #F3F4F6;
        padding: 1rem 1.5rem;
    }
    .field-label {
        font-size: .73rem;
        font-weight: 700;
        color: #9CA3AF;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 5px;
        display: block;
    }
    .field-input {
        border: 1.5px solid #E5E7EB;
        border-radius: 9px;
        padding: 9px 13px;
        font-size: .875rem;
        font-weight: 400;
        color: #374151;
        width: 100%;
        outline: none;
        background: #FAFAFA;
        transition: border-color .2s, box-shadow .2s;
        display: block;
    }
    .field-input:focus {
        border-color: #C8102E;
        box-shadow: 0 0 0 3px rgba(200,16,46,.08);
        background: #fff;
    }
    .btn-save {
        background: #C8102E;
        color: #fff;
        border: none;
        padding: 9px 24px;
        border-radius: 9px;
        font-size: .875rem;
        font-weight: 600;
        transition: background .2s, transform .15s;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .btn-save:hover { background: #a50d25; transform: translateY(-1px); }
    .btn-cancel-modal {
        background: #F3F4F6;
        color: #6B7280;
        border: none;
        padding: 9px 18px;
        border-radius: 9px;
        font-size: .875rem;
        font-weight: 500;
        cursor: pointer;
        transition: background .15s;
    }
    .btn-cancel-modal:hover { background: #E5E7EB; }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: #B0B7C3;
    }
    .empty-state i { font-size: 2.5rem; margin-bottom: .75rem; display: block; }
    .empty-state p { font-size: .9rem; margin: 0; }
</style>

<div class="users-page">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title">Users</h1>
            <p class="page-subtitle">Manage system admin and cashier accounts</p>
        </div>
        <button class="btn-add" data-bs-toggle="modal" data-bs-target="#addUserModal">
            <i class="bi bi-person-plus-fill"></i> Add User
        </button>
    </div>

    <!-- CARD -->
    <div class="custom-card">

        <!-- SEARCH -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="search-wrap">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" id="searchInput" class="search-box"
                           placeholder="Search by name, username or role…" />
                </div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="table-responsive">
            <table class="users-table" id="usersTable">
                <thead>
                    <tr>
                        <th style="width:58px;">ID</th>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th style="width:115px;">Password</th>
                        <th style="width:115px;">Role</th>
                        <th style="width:185px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <i class="bi bi-people"></i>
                                    <p>No users found.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var user in Model)
                        {
                            var roleClass = (user.Role ?? "").ToLower() switch {
                                "admin"   => "role-admin",
                                "cashier" => "role-cashier",
                                "teacher" => "role-teacher",
                                "student" => "role-student",
                                _         => "role-admin"
                            };
                            <tr>
                                <td><span class="uid-chip">@user.UserId</span></td>
                                <td><span class="user-fullname">@(string.IsNullOrWhiteSpace(user.FullName) ? "—" : user.FullName)</span></td>
                                <td><span class="user-username">@user.Username</span></td>
                                <td><span class="pwd-mask">••••</span></td>
                                <td><span class="role-badge @roleClass">@user.Role</span></td>
                                <td>
                                    <div class="actions-cell">
                                        <a class="btn-action btn-view" href="/User/View/@user.UserId">
                                            <i class="bi bi-eye-fill"></i> View
                                        </a>
                                        <a class="btn-action btn-edit" href="/User/Edit/@user.UserId">
                                            <i class="bi bi-pencil-fill"></i> Edit
                                        </a>
                                        <a class="btn-action btn-delete" href="/User/Delete/@user.UserId"
                                           onclick="return confirm('Are you sure you want to delete this user?')">
                                            <i class="bi bi-trash-fill"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

    </div><!-- /custom-card -->

</div><!-- /users-page -->


<!-- ADD USER MODAL -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="/User/Create">

                <div class="modal-header">
                    <span class="modal-title-text" id="addUserModalLabel">
                        <i class="bi bi-person-plus-fill text-danger"></i>
                        Add New User
                    </span>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="field-label">Full Name</label>
                        <input name="FullName" class="field-input" placeholder="e.g. Juan dela Cruz" required />
                    </div>
                    <div class="mb-3">
                        <label class="field-label">Username / Email</label>
                        <input name="Username" class="field-input" placeholder="e.g. juandc or juan@school.edu" required />
                    </div>
                    <div class="mb-3">
                        <label class="field-label">Password</label>
                        <input name="Password" type="password" class="field-input" placeholder="Enter a secure password" required />
                    </div>
                    <div class="mb-1">
                        <label class="field-label">Role</label>
                        <select name="Role" class="field-input" style="cursor:pointer; appearance:auto;">
                            <option value="Admin">Admin</option>
                            <option value="Cashier">Cashier</option>
                        </select>
                    </div>
                </div>

                <div class="modal-footer justify-content-end gap-2">
                    <button type="button" class="btn-cancel-modal" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-save">
                        <i class="bi bi-check2-circle"></i> Save User
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>


<script>
    document.getElementById("searchInput").addEventListener("keyup", function () {
        const val = this.value.toLowerCase();
        document.querySelectorAll("#usersTable tbody tr").forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(val) ? "" : "none";
        });
    });
</script>